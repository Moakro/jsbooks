---
import Base from "../../../../layouts/Base.astro";
import { getCollection } from "astro:content";
import { buildCardManifest } from "../../../../lib/manifest";
import { renderWikilinks } from "../../../../lib/wikilink";
import { parseVerses } from "../../../../lib/verse-parser";
import { getMapping, resolveHangeulVerses } from "../../../../lib/canonical-mapping";
import ScriptureChapterNav from "../../../../components/ScriptureChapterNav.astro";
import ScriptureStickyBar from "../../../../components/ScriptureStickyBar.astro";
import AdminGate from "../../../../components/AdminGate.astro";

export async function getStaticPaths() {
  const all = await getCollection("scripture");
  return all
    .filter((e) => e.id.startsWith("cheonjigaebyeokgyeong-canonical/") && e.data.권 && e.data.장)
    .map((e) => ({
      params: { vol: String(e.data.권), chap: String(e.data.장) },
      props: { entry: e },
    }));
}

const { entry } = Astro.props;
const { 권, 권_이름, 권_이름_한자, 장, 연도, 연도_간지 } = entry.data;
const manifest = await buildCardManifest();

type Verse = {
  num: number;
  id: string;
  hanjaHTML: string;
  hangeul: { id: string; num: number; html: string }[];
  reviewed: boolean;
  confidence?: number;
};
const parsed = parseVerses(entry.body ?? "");
const verses: Verse[] = [];
for (const v of parsed) {
  const paragraphs = v.text.split(/\n\s*\n/).filter(Boolean);
  const hanjaHTML = paragraphs
    .map((p) => renderWikilinks(p, manifest))
    .join("\n\n");
  const mapping = getMapping(v.id);
  const hangeulAnchors = mapping?.hangeul ?? [];
  const hangeulVerses = await resolveHangeulVerses(hangeulAnchors);
  const hangeul = hangeulVerses.map((hv) => ({
    id: hv.id,
    num: hv.num,
    html: hv.body
      .split(/\n\s*\n/)
      .filter(Boolean)
      .map((p) => renderWikilinks(p, manifest))
      .join("\n\n"),
  }));
  verses.push({
    num: v.num,
    id: v.id,
    hanjaHTML,
    hangeul,
    reviewed: mapping?.reviewed ?? false,
    confidence: mapping?.confidence,
  });
}

// Same-volume index
const all = await getCollection("scripture");
const sameVol = all
  .filter((e) => e.id.startsWith("cheonjigaebyeokgyeong-canonical/") && e.data.권 === 권 && e.data.장)
  .sort((a, b) => (a.data.장 ?? 0) - (b.data.장 ?? 0));
const idx = sameVol.findIndex((e) => e.id === entry.id);
const totalChaps = sameVol.length;
const chapPct = Math.round(((idx + 1) / totalChaps) * 100);

// Redirect target if non-admin (matches the temp page's URL).
const redirectTo = `/library/cheonjigaebyeokgyeong/${권}/${장}/`;
---

<Base title={`권 ${권} ${권_이름} · ${장}장 — 천지개벽경 (정식판)`} scriptureSlug="cheonjigaebyeokgyeong-canonical">
  <AdminGate redirect={redirectTo}>
    <ScriptureStickyBar
      scriptureName="천지개벽경 (정식판)"
      scriptureSlug="cheonjigaebyeokgyeong-canonical"
      scriptureHref="/library/cheonjigaebyeokgyeong-canonical/"
      context={`권 ${권} ${권_이름} · ${장}장`}
    />
    <div class="chap-head">
      <h1>{장}장 <span class="badge">정식판 / 원문</span></h1>
      <p class="meta">{연도_간지} {연도}</p>
    </div>
    <div class="chap-progress" aria-label={`이 권의 ${idx + 1}번째 장 / 전체 ${totalChaps}장`}>
      <div class="bar"><div class="fill" style={`width: ${chapPct}%`}></div></div>
      <span class="meta">{idx + 1} / {totalChaps}장</span>
    </div>

    <div class="display-modes" data-display-modes>
      <label><input type="checkbox" data-mode="hanja" checked /> 원문</label>
      <label><input type="checkbox" data-mode="hangeul" checked /> 한글본</label>
    </div>

    <div>
      {verses.map((v) => (
        <section class="verse" data-reviewed={v.reviewed ? "true" : "false"}>
          <h3 class="verse-anchor-heading" id={v.id}>{v.num}절</h3>
          <div class="verse-label">
            <a href={`#${v.id}`}>{v.num}절</a>
            <span style="margin-left: 0.5rem; opacity: 0.5">^{v.id}</span>
            {v.hangeul.length === 0 && (
              <span class="badge unmapped">한글 미매핑</span>
            )}
            {v.hangeul.length > 0 && !v.reviewed && (
              <span class="badge unreviewed">검수전</span>
            )}
          </div>
          <div class="verse-body hanja" data-layer="hanja" set:html={v.hanjaHTML} />
          {v.hangeul.length > 0 && (
            <div class="verse-body hangeul" data-layer="hangeul">
              {v.hangeul.map((h) => (
                <p class="hangeul-line" set:html={h.html} />
              ))}
            </div>
          )}
        </section>
      ))}
    </div>

    <script is:inline>
      (function () {
        const wrap = document.querySelector("[data-display-modes]");
        if (!wrap) return;
        const update = () => {
          const showHanja = wrap.querySelector('[data-mode="hanja"]').checked;
          const showHangeul = wrap.querySelector('[data-mode="hangeul"]').checked;
          document.body.classList.toggle("hide-hanja", !showHanja);
          document.body.classList.toggle("hide-hangeul", !showHangeul);
        };
        wrap.addEventListener("change", update);
        update();
      })();
    </script>

    <ScriptureChapterNav scriptureSlug="cheonjigaebyeokgyeong-canonical" currentId={entry.id} />
  </AdminGate>
</Base>

<style>
  .badge {
    font-size: 0.5em;
    font-weight: normal;
    color: var(--color-muted);
    border: 1px solid var(--color-rule);
    border-radius: 4px;
    padding: 0.15rem 0.4rem;
    margin-left: 0.4rem;
    vertical-align: middle;
  }
  .chap-head {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    flex-wrap: wrap;
  }
  .chap-head h1 {
    margin: 0;
  }
  .chap-head .meta {
    margin: 0;
  }
  .chap-progress {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin: 0.4rem 0 1.5rem;
  }
  .chap-progress .bar {
    flex: 1;
    height: 4px;
    background: var(--color-rule);
    border-radius: 999px;
    overflow: hidden;
  }
  .chap-progress .fill {
    height: 100%;
    background: var(--color-primary);
    border-radius: 999px;
    transition: width 0.3s ease;
  }
  .chap-progress .meta {
    font-size: 0.78rem;
    color: var(--color-muted);
    flex-shrink: 0;
  }
  .verse-body :global(p) {
    margin: 0.5rem 0;
  }
  .verse-body.hangeul {
    margin-top: 0.4rem;
    padding-left: 0.7rem;
    border-left: 2px solid var(--color-rule);
    color: var(--color-fg);
  }
  .hangeul-line {
    margin: 0.4rem 0;
    line-height: 1.85;
  }
  :global(body.hide-hanja) .verse-body.hanja {
    display: none;
  }
  :global(body.hide-hangeul) .verse-body.hangeul {
    display: none;
  }
  .display-modes {
    display: flex;
    gap: 1rem;
    margin: 0 0 1.5rem;
    padding: 0.5rem 0.7rem;
    border: 1px solid var(--color-rule);
    border-radius: 6px;
    background: var(--color-surface-2);
    font-size: 0.85rem;
  }
  .display-modes label {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    cursor: pointer;
  }
  .badge {
    font-size: 0.7em;
    border-radius: 4px;
    padding: 0.1rem 0.35rem;
    margin-left: 0.4rem;
  }
  .badge.unmapped {
    background: var(--color-rule);
    color: var(--color-muted);
  }
  .badge.unreviewed {
    background: var(--color-secondary-bg, #fff3e0);
    color: var(--color-secondary, #d97706);
  }
  .verse-anchor-heading {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
