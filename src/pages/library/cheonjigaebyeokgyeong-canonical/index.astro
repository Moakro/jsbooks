---
import Base from "../../../layouts/Base.astro";
import { getCollection } from "astro:content";
import ScriptureStickyBar from "../../../components/ScriptureStickyBar.astro";
import AdminGate from "../../../components/AdminGate.astro";

const allScripture = await getCollection("scripture");
const all = allScripture.filter((e) => e.id.startsWith("cheonjigaebyeokgyeong-canonical/"));

// Preface (00_서)
const preface = all.find((e) => e.id === "cheonjigaebyeokgyeong-canonical/00_서");

// Group by 권
const volumes = new Map<number, { name: string; hanja: string; year: number; ganji: string; chapters: typeof all }>();
for (const e of all) {
  if (!e.data.권) continue;
  const v = e.data.권;
  if (!volumes.has(v)) {
    volumes.set(v, {
      name: e.data.권_이름 ?? "",
      hanja: e.data.권_이름_한자 ?? "",
      year: e.data.연도 ?? 0,
      ganji: e.data.연도_간지 ?? "",
      chapters: [] as any,
    });
  }
  volumes.get(v)!.chapters.push(e);
}
for (const v of volumes.values()) {
  v.chapters.sort((a, b) => (a.data.장 ?? 0) - (b.data.장 ?? 0));
}
const volList = [...volumes.entries()].sort(([a], [b]) => a - b);
---

<Base title="천지개벽경 (정식판) — jsbooks" scriptureSlug="cheonjigaebyeokgyeong-canonical">
  <AdminGate redirect="/library/cheonjigaebyeokgyeong/">
    <ScriptureStickyBar scriptureName="천지개벽경 (정식판)" scriptureSlug="cheonjigaebyeokgyeong-canonical" />
    <p class="meta"><a href="/library/">← 서재</a></p>
    <h1>천지개벽경 (天地開闢經) <span class="badge">정식판 / 원문</span></h1>
    <p class="meta">한자 원문 · 한글본 매핑 작업 중 (관리자 전용)</p>

    {preface && (
      <section class="vol-section">
        <h2>
          서문
        </h2>
        <div class="chap-grid">
          <a class="chap-btn" href="/library/cheonjigaebyeokgyeong-canonical/preface/">序</a>
        </div>
      </section>
    )}

    {volList.map(([num, vol]) => (
      <section class="vol-section">
        <h2>
          권 {num} · {vol.name} ({vol.hanja})
          <span class="vol-meta">{vol.ganji} {vol.year}</span>
        </h2>
        <div class="chap-grid">
          {vol.chapters.map((c) => (
            <a class="chap-btn" href={`/library/cheonjigaebyeokgyeong-canonical/${num}/${c.data.장}/`}>
              {c.data.장}
            </a>
          ))}
        </div>
      </section>
    ))}
  </AdminGate>
</Base>

<style>
  .badge {
    font-size: 0.7em;
    font-weight: normal;
    color: var(--color-muted);
    border: 1px solid var(--color-rule);
    border-radius: 4px;
    padding: 0.15rem 0.4rem;
    margin-left: 0.4rem;
    vertical-align: middle;
  }
  .vol-section {
    margin: 1.6rem 0 0;
  }
  .vol-section h2 {
    display: flex;
    align-items: baseline;
    gap: 0.55rem;
    flex-wrap: wrap;
    margin-bottom: 0.7rem;
  }
  .vol-meta {
    font-size: 0.85rem;
    font-weight: normal;
    color: var(--color-muted);
  }
  .chap-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(54px, 1fr));
    gap: 0.4rem;
  }
  .chap-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    padding: 0.4rem 0.6rem;
    border: 1px solid var(--color-rule);
    border-radius: 6px;
    background: var(--color-bg);
    color: var(--color-fg);
    font-size: 0.95rem;
    text-decoration: none;
    transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease, transform 0.15s ease;
  }
  .chap-btn:hover {
    background: var(--color-primary-bg);
    border-color: var(--color-primary);
    color: var(--color-primary);
    transform: translateY(-1px);
  }
  @media (min-width: 720px) {
    .chap-grid {
      grid-template-columns: repeat(auto-fill, minmax(64px, 1fr));
    }
  }
</style>
