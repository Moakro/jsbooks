---
import Base from "../../../layouts/Base.astro";
import { getCollection } from "astro:content";
import { buildCardManifest } from "../../../lib/manifest";
import { renderMarkdownBody } from "../../../lib/wikilink";
import ScriptureChapterNav from "../../../components/ScriptureChapterNav.astro";
import ScriptureStickyBar from "../../../components/ScriptureStickyBar.astro";

const all = await getCollection("scripture");
const preface = all.find((e) => e.id === "donggokbiseo/00_서");
if (!preface) throw new Error("donggokbiseo/00_서.md not found");

const manifest = await buildCardManifest();
const bodyHTML = renderMarkdownBody(preface.body ?? "", manifest);
---

<Base
  title="서(序) — 동곡비서"
  scriptureSlug="donggokbiseo"
  chapterAnchor="preface"
  chapterLabel="서(序)"
>
  <ScriptureStickyBar
    scriptureName="동곡비서"
    scriptureSlug="donggokbiseo"
    scriptureHref="/library/donggokbiseo/"
    context="서(序)"
  />
  <h1>동곡비서 서(序)</h1>
  <p class="meta">{preface.data.date_lunar}</p>
  <div
    data-pagefind-body
    data-pagefind-filter="scripture:donggokbiseo"
    data-pagefind-meta="title:서(序)"
  >
    <span hidden data-pagefind-filter="kind:경전"></span>
    <span hidden data-pagefind-meta="scriptureName:동곡비서"></span>
    <article class="prose-body" set:html={bodyHTML} />
  </div>

  <p style="text-align: right; margin-top: 3rem;">
    1990년(庚午) 五월 五일<br />
    전주동곡 이제원에서<br />
    <strong>이춘풍(李春風) 엮음</strong>
  </p>

  <ScriptureChapterNav scriptureSlug="donggokbiseo" currentId={preface.id} />
</Base>

<style>
  .prose-body :global(h1),
  .prose-body :global(p) {
    line-height: 1.85;
  }
</style>
