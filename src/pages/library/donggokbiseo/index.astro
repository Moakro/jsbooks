---
import Base from "../../../layouts/Base.astro";
import { getCollection } from "astro:content";
import { buildCardManifest } from "../../../lib/manifest";
import { renderWikilinks } from "../../../lib/wikilink";
import { parseVerses } from "../../../lib/verse-parser";
import { correspondencesFor } from "../../../lib/correspondences";
import CorrespondenceBadges from "../../../components/CorrespondenceBadges.astro";
import ScriptureChapterNav from "../../../components/ScriptureChapterNav.astro";
import ScriptureStickyBar from "../../../components/ScriptureStickyBar.astro";
import ScriptureVersionTag from "../../../components/ScriptureVersionTag.astro";
import AiMatchNotice from "../../../components/AiMatchNotice.astro";

const all = await getCollection("scripture");
const verses_entry = all.find((e) => e.id === "donggokbiseo/01_본문");
if (!verses_entry) throw new Error("donggokbiseo/01_본문.md not found");

const manifest = await buildCardManifest();

type Verse = { num: number; id: string; html: string };
const verses: Verse[] = parseVerses(verses_entry.body ?? "").map((v) => {
  const paragraphs = v.text.split(/\n\s*\n/).filter(Boolean);
  const html = paragraphs
    .map((p) => renderWikilinks(p, manifest))
    .join("\n\n");
  return { num: v.num, id: v.id, html };
});
---

<Base
  title="동곡비서 (銅谷秘書) — jsbooks"
  scriptureSlug="donggokbiseo"
  chapterAnchor="0"
  chapterLabel="동곡비서 본문"
>
  <ScriptureStickyBar
    scriptureName="동곡비서"
    scriptureSlug="donggokbiseo"
    context="본문"
  />
  <p class="meta"><a href="/library/">← 서재</a></p>
  <h1>동곡비서 (銅谷秘書)</h1>
  <p class="meta">이춘풍(李春風) 엮음 · 1990년 5월 5일 (경오년)</p>
  <ScriptureVersionTag slug="donggokbiseo" />

  <p class="meta" style="font-size: 0.9rem; margin-top: 0.5rem">
    본문 {verses.length}절. 권·장 위계 없이 평면 시퀀스로 수록되어 있습니다.
  </p>

  <ScriptureChapterNav scriptureSlug="donggokbiseo" currentId={verses_entry.id} placement="top" />

  <AiMatchNotice />

  <hr style="margin: 1.5rem 0; border: none; border-top: 1px solid var(--rule)" />

  <div
    data-pagefind-body
    data-pagefind-filter="scripture:donggokbiseo"
    data-pagefind-meta="title:동곡비서"
  >
    <span hidden data-pagefind-filter="kind:경전"></span>
    <span hidden data-pagefind-meta="scriptureName:동곡비서"></span>
    {verses.map((v) => (
      <section class="verse">
        <h3 class="verse-anchor-heading" id={v.id}>{v.num}절</h3>
        <div class="verse-label" data-pagefind-ignore>
          <a href={`#${v.id}`}>{v.num}절</a>
          <span style="margin-left: 0.5rem; opacity: 0.5">^{v.id}</span>
          <CorrespondenceBadges matches={correspondencesFor("donggokbiseo", v.id)} />
        </div>
        <div class="verse-body" set:html={v.html} />
      </section>
    ))}
  </div>

  <ScriptureChapterNav scriptureSlug="donggokbiseo" currentId={verses_entry.id} />
</Base>

<style>
  .verse-anchor-heading {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>

