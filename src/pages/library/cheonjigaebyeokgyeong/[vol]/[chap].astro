---
import Base from "../../../../layouts/Base.astro";
import History from "../../../../components/History.astro";
import Comments from "../../../../components/Comments.svelte";
import { getCollection } from "astro:content";
import { buildCardManifest } from "../../../../lib/manifest";
import { renderWikilinks } from "../../../../lib/wikilink";
import { correspondencesFor } from "../../../../lib/correspondences";
import CorrespondenceBadges from "../../../../components/CorrespondenceBadges.astro";
import ScriptureChapterNav from "../../../../components/ScriptureChapterNav.astro";
import ScriptureStickyBar from "../../../../components/ScriptureStickyBar.astro";

export async function getStaticPaths() {
  const all = await getCollection("scripture");
  return all
    .filter((e) => e.data.권 && e.data.장)
    .map((e) => ({
      params: { vol: String(e.data.권), chap: String(e.data.장) },
      props: { entry: e },
    }));
}

const { entry } = Astro.props;
const { 권, 권_이름, 권_이름_한자, 장, 연도, 연도_간지 } = entry.data;
const manifest = await buildCardManifest();

// Parse body into verses by ## N절 ^X-Y-Z headings
type Verse = { num: number; id: string; html: string };
const body = entry.body ?? "";
const versePattern = /^## (\d+)절 \^(\S+)\s*\n([\s\S]*?)(?=^## \d+절|\Z)/gm;
const verses: Verse[] = [];
let m: RegExpExecArray | null;
while ((m = versePattern.exec(body)) !== null) {
  const num = parseInt(m[1], 10);
  const id = m[2];
  const raw = m[3].trim();
  // Convert paragraph breaks: keep newlines as <br> for poetry, paragraphs separated by blank line
  const paragraphs = raw.split(/\n\s*\n/).filter(Boolean);
  const inner = paragraphs
    .map((p) => renderWikilinks(p.replaceAll("\n", "\n"), manifest))
    .join("\n\n");
  verses.push({ num, id, html: inner });
}

// Same-volume index (for the progress indicator at the top)
const all = await getCollection("scripture");
const sameVol = all
  .filter((e) => e.data.권 === 권 && e.data.장)
  .sort((a, b) => (a.data.장 ?? 0) - (b.data.장 ?? 0));
const idx = sameVol.findIndex((e) => e.id === entry.id);
const totalChaps = sameVol.length;
const chapPct = Math.round(((idx + 1) / totalChaps) * 100);

// entry.id is like "cheonjigaebyeokgyeong/02_임인편/02-01_장" — reconstruct the content/ path.
const historyPath = `content/scripture/${entry.id}.md`;
---

<Base title={`권 ${권} ${권_이름} · ${장}장 — 천지개벽경`} scriptureSlug="cheonjigaebyeokgyeong">
  <ScriptureStickyBar
    scriptureName="천지개벽경"
    scriptureSlug="cheonjigaebyeokgyeong"
    scriptureHref="/library/cheonjigaebyeokgyeong/"
    context={`권 ${권} ${권_이름} · ${장}장`}
  />
  <div class="chap-head">
    <h1>{장}장</h1>
    <p class="meta">{연도_간지} {연도}</p>
  </div>
  <div class="chap-progress" aria-label={`이 권의 ${idx + 1}번째 장 / 전체 ${totalChaps}장`}>
    <div class="bar"><div class="fill" style={`width: ${chapPct}%`}></div></div>
    <span class="meta">{idx + 1} / {totalChaps}장</span>
  </div>

  <div
    data-pagefind-body
    data-pagefind-filter="scripture:cheonjigaebyeokgyeong"
    data-pagefind-meta={`title:권 ${권} ${권_이름} ${장}장`}
  >
    <span hidden data-pagefind-filter="kind:경전"></span>
    <span hidden data-pagefind-meta="scriptureName:천지개벽경"></span>
    {verses.map((v) => (
      <section class="verse">
        <h3 class="verse-anchor-heading" id={v.id}>{v.num}절</h3>
        <div class="verse-label" data-pagefind-ignore>
          <a href={`#${v.id}`}>{v.num}절</a>
          <span style="margin-left: 0.5rem; opacity: 0.5">^{v.id}</span>
          <CorrespondenceBadges matches={correspondencesFor("cheonjigaebyeokgyeong", v.id)} />
        </div>
        <div class="verse-body" set:html={v.html} />
      </section>
    ))}
  </div>

  <ScriptureChapterNav scriptureSlug="cheonjigaebyeokgyeong" currentId={entry.id} />

  <Comments client:idle target={`chapter:${권}:${장}`} />
  <History path={historyPath} />
</Base>

<style>
  .chap-head {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    flex-wrap: wrap;
  }
  .chap-head h1 {
    margin: 0;
  }
  .chap-head .meta {
    margin: 0;
  }
  .chap-progress {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin: 0.4rem 0 1.5rem;
  }
  .chap-progress .bar {
    flex: 1;
    height: 4px;
    background: var(--color-rule);
    border-radius: 999px;
    overflow: hidden;
  }
  .chap-progress .fill {
    height: 100%;
    background: var(--color-primary);
    border-radius: 999px;
    transition: width 0.3s ease;
  }
  .chap-progress .meta {
    font-size: 0.78rem;
    color: var(--color-muted);
    flex-shrink: 0;
  }
  .verse-body :global(p) {
    margin: 0.5rem 0;
  }
  .verse-anchor-heading {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
