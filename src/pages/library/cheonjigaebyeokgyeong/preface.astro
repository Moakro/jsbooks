---
import Base from "../../../layouts/Base.astro";
import { getCollection } from "astro:content";
import { buildCardManifest } from "../../../lib/manifest";
import { renderWikilinks } from "../../../lib/wikilink";
import { parseVerseGroups } from "../../../lib/verse-parser";
import Comments from "../../../components/Comments.svelte";
import History from "../../../components/History.astro";
import ScriptureChapterNav from "../../../components/ScriptureChapterNav.astro";
import ScriptureStickyBar from "../../../components/ScriptureStickyBar.astro";

const all = await getCollection("scripture");
const preface = all.find((e) => e.id === "cheonjigaebyeokgyeong/00_서");
if (!preface) throw new Error("cheonjigaebyeokgyeong/00_서.md not found");

const manifest = await buildCardManifest();

type Sentence = {
  anchor: string;
  /** 1-based sentence index within preface (평면 모델). */
  sentenceNum: number;
  html: string;
};
const sentences: Sentence[] = [];
let sentenceIdx = 0;
for (const g of parseVerseGroups(preface.body ?? "")) {
  for (const s of g.sentences) {
    sentenceIdx++;
    sentences.push({
      anchor: s.anchor,
      sentenceNum: sentenceIdx,
      html: renderWikilinks(s.text, manifest),
    });
  }
}

const historyPath = `content/scripture/${preface.id}.md`;
---

<Base title="서(序) — 천지개벽경" scriptureSlug="cheonjigaebyeokgyeong">
  <ScriptureStickyBar
    scriptureName="천지개벽경"
    scriptureSlug="cheonjigaebyeokgyeong"
    scriptureHref="/library/cheonjigaebyeokgyeong/"
    context="서(序)"
    versePrefix="#"
    verseSuffix=""
  />
  <h1>천지개벽경 서(序)</h1>

  <div
    data-pagefind-body
    data-pagefind-filter="scripture:cheonjigaebyeokgyeong"
    data-pagefind-meta="title:서(序)"
  >
    <span hidden data-pagefind-filter="kind:경전"></span>
    <span hidden data-pagefind-meta="scriptureName:천지개벽경"></span>
    {sentences.map((s) => (
      <section class="verse" data-sentence-num={s.sentenceNum}>
        <h4 class="verse-anchor-heading" id={s.anchor}>^{s.anchor}</h4>
        <div class="verse-label" data-pagefind-ignore>
          <a href={`#${s.anchor}`}>^{s.anchor}</a>
        </div>
        <div class="verse-body" set:html={s.html} />
      </section>
    ))}
  </div>

  <p style="text-align: right; margin-top: 3rem;">
    <strong>이중성(李重盛) 序</strong>
  </p>

  <ScriptureChapterNav scriptureSlug="cheonjigaebyeokgyeong" currentId={preface.id} />

  <Comments client:idle target={`preface`} />
  <History path={historyPath} />
</Base>

<style>
  .verse-body :global(p) {
    margin: 0.5rem 0;
    line-height: 1.85;
  }
  .verse-anchor-heading {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .verse.group-start {
    margin-top: 1.4rem;
  }
  .verse.group-start:first-child {
    margin-top: 0;
  }
  .group-heading {
    margin: 0 0 0.4rem;
    font-size: 1rem;
    color: var(--color-primary);
    font-weight: 600;
  }
</style>
