---
import Base from "../../../layouts/Base.astro";
import { getCollection } from "astro:content";
import { buildCardManifest } from "../../../lib/manifest";
import { renderWikilinks } from "../../../lib/wikilink";
import { parseVerses } from "../../../lib/verse-parser";
import Comments from "../../../components/Comments.svelte";
import History from "../../../components/History.astro";
import ScriptureChapterNav from "../../../components/ScriptureChapterNav.astro";
import ScriptureStickyBar from "../../../components/ScriptureStickyBar.astro";

const all = await getCollection("scripture");
const preface = all.find((e) => e.id === "cheonjigaebyeokgyeong/00_서");
if (!preface) throw new Error("cheonjigaebyeokgyeong/00_서.md not found");

const manifest = await buildCardManifest();

type Verse = { num: number; id: string; html: string };
const verses: Verse[] = parseVerses(preface.body ?? "").map((v) => {
  const paragraphs = v.text.split(/\n\s*\n/).filter(Boolean);
  const html = paragraphs
    .map((p) => renderWikilinks(p, manifest))
    .join("\n\n");
  return { num: v.num, id: v.id, html };
});

const historyPath = `content/scripture/${preface.id}.md`;
---

<Base title="서(序) — 천지개벽경" scriptureSlug="cheonjigaebyeokgyeong">
  <ScriptureStickyBar
    scriptureName="천지개벽경"
    scriptureSlug="cheonjigaebyeokgyeong"
    scriptureHref="/library/cheonjigaebyeokgyeong/"
    context="서(序)"
  />
  <h1>천지개벽경 서(序)</h1>

  <div>
    {verses.map((v) => (
      <section class="verse">
        <h3 class="verse-anchor-heading" id={v.id}>{v.num}절</h3>
        <div class="verse-label">
          <a href={`#${v.id}`}>{v.num}절</a>
          <span style="margin-left: 0.5rem; opacity: 0.5">^{v.id}</span>
        </div>
        <div class="verse-body" set:html={v.html} />
      </section>
    ))}
  </div>

  <p style="text-align: right; margin-top: 3rem;">
    <strong>이중성(李重盛) 序</strong>
  </p>

  <ScriptureChapterNav scriptureSlug="cheonjigaebyeokgyeong" currentId={preface.id} />

  <Comments client:idle target={`preface`} />
  <History path={historyPath} />
</Base>

<style>
  .verse-body :global(p) {
    margin: 0.5rem 0;
    line-height: 1.85;
  }
  .verse-anchor-heading {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
