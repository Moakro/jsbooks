---
import Base from "../../../layouts/Base.astro";
import Comments from "../../../components/Comments.svelte";
import History from "../../../components/History.astro";
import { getCollection } from "astro:content";
import { buildCardManifest } from "../../../lib/manifest";
import { renderMarkdownBody } from "../../../lib/wikilink";
import ScriptureChapterNav from "../../../components/ScriptureChapterNav.astro";
import ScriptureStickyBar from "../../../components/ScriptureStickyBar.astro";

const all = await getCollection("scripture");
const appendix = all.find((e) => e.id === "hwaeundang-silgi/99_부록");
if (!appendix) throw new Error("hwaeundang-silgi/99_부록.md not found");

const manifest = await buildCardManifest();
const bodyHTML = renderMarkdownBody(appendix.body ?? "", manifest);

const historyPath = `content/scripture/${appendix.id}.md`;
---

<Base title="부록 — 화은당실기" scriptureSlug="hwaeundang-silgi">
  <ScriptureStickyBar
    scriptureName="화은당실기"
    scriptureSlug="hwaeundang-silgi"
    scriptureHref="/library/hwaeundang-silgi/"
    context="부록"
  />

  <div
    data-pagefind-body
    data-pagefind-filter="scripture:hwaeundang-silgi"
    data-pagefind-meta="title:부록"
  >
    <span hidden data-pagefind-filter="kind:경전"></span>
    <span hidden data-pagefind-meta="scriptureName:화은당실기"></span>
    <article class="prose-body" set:html={bodyHTML} />
  </div>

  <ScriptureChapterNav scriptureSlug="hwaeundang-silgi" currentId={appendix.id} />

  <Comments client:idle target={`appendix`} />
  <History path={historyPath} />
</Base>

<style>
  .prose-body :global(h1) {
    font-size: 1.5rem;
    margin: 0 0 1.2rem;
  }
  .prose-body :global(p) {
    margin: 0.7rem 0;
    line-height: 1.85;
  }
</style>
