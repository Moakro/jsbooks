---
import Base from "../../../layouts/Base.astro";
import Comments from "../../../components/Comments.svelte";
import History from "../../../components/History.astro";
import { getCollection } from "astro:content";
import { buildCardManifest } from "../../../lib/manifest";
import { renderWikilinks } from "../../../lib/wikilink";
import { parseVerses } from "../../../lib/verse-parser";
import ScriptureChapterNav from "../../../components/ScriptureChapterNav.astro";
import ScriptureStickyBar from "../../../components/ScriptureStickyBar.astro";
import ScriptureCommentLayer from "../../../components/scripture/ScriptureCommentLayer.svelte";

export async function getStaticPaths() {
  const all = await getCollection("scripture");
  return all
    .filter((e) => e.id.startsWith("hwaeundang-silgi/") && e.data.장)
    .map((e) => ({
      params: { chap: String(e.data.장) },
      props: { entry: e },
    }));
}

const { entry } = Astro.props;
const 장 = entry.data.장!;
const 장_이름 = entry.data.장_이름 ?? "";
const manifest = await buildCardManifest();

type Verse = { num: number; id: string; html: string };
const verses: Verse[] = parseVerses(entry.body ?? "").map((v) => {
  const paragraphs = v.text.split(/\n\s*\n/).filter(Boolean);
  const html = paragraphs
    .map((p) => renderWikilinks(p, manifest))
    .join("\n\n");
  return { num: v.num, id: v.id, html };
});

const all = await getCollection("scripture");
const sameScripture = all
  .filter((e) => e.id.startsWith("hwaeundang-silgi/") && e.data.장)
  .sort((a, b) => (a.data.장 ?? 0) - (b.data.장 ?? 0));
const idx = sameScripture.findIndex((e) => e.id === entry.id);
const totalChaps = sameScripture.length;
const chapPct = Math.round(((idx + 1) / totalChaps) * 100);

const historyPath = `content/scripture/${entry.id}.md`;
---

<Base title={`제${장}장 ${장_이름} — 화은당실기`} scriptureSlug="hwaeundang-silgi">
  <ScriptureStickyBar
    scriptureName="화은당실기"
    scriptureSlug="hwaeundang-silgi"
    scriptureHref="/library/hwaeundang-silgi/"
    context={`제${장}장 ${장_이름}`}
  />
  <div class="chap-head">
    <h1>제{장}장 {장_이름}</h1>
  </div>
  <div class="chap-progress" aria-label={`${idx + 1}번째 장 / 전체 ${totalChaps}장`}>
    <div class="bar"><div class="fill" style={`width: ${chapPct}%`}></div></div>
    <span class="meta">{idx + 1} / {totalChaps}장</span>
  </div>

  <div
    data-pagefind-body
    data-pagefind-filter="scripture:hwaeundang-silgi"
    data-pagefind-meta={`title:제${장}장 ${장_이름}`}
  >
    <span hidden data-pagefind-filter="kind:경전"></span>
    <span hidden data-pagefind-meta="scriptureName:화은당실기"></span>
    {verses.map((v) => (
      <section class="verse">
        <h3 class="verse-anchor-heading" id={v.id}>{v.num}절</h3>
        <div class="verse-label" data-pagefind-ignore>
          <a href={`#${v.id}`}>{v.num}절</a>
          <span style="margin-left: 0.5rem; opacity: 0.5">^{v.id}</span>
        </div>
        <div class="verse-body" set:html={v.html} />
      </section>
    ))}
  </div>

  <ScriptureChapterNav scriptureSlug="hwaeundang-silgi" currentId={entry.id} />

  <Comments client:idle target={`chapter:${장}`} />
  <History path={historyPath} />

  <ScriptureCommentLayer client:only="svelte" slug="hwaeundang-silgi" />
</Base>

<style>
  .chap-head { display: flex; align-items: baseline; gap: 0.7rem; flex-wrap: wrap; }
  .chap-head h1 { margin: 0; }
  .chap-progress {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin: 0.4rem 0 1.5rem;
  }
  .chap-progress .bar {
    flex: 1;
    height: 4px;
    background: var(--color-rule);
    border-radius: 999px;
    overflow: hidden;
  }
  .chap-progress .fill {
    height: 100%;
    background: var(--color-primary);
    border-radius: 999px;
    transition: width 0.3s ease;
  }
  .chap-progress .meta {
    font-size: 0.78rem;
    color: var(--color-muted);
    flex-shrink: 0;
  }
  .verse-body :global(p) {
    margin: 0.5rem 0;
  }
  .verse-anchor-heading {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
