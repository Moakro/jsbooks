---
import Base from "../../../../layouts/Base.astro";
import History from "../../../../components/History.astro";
import Comments from "../../../../components/Comments.svelte";
import { getCollection } from "astro:content";
import { buildCardManifest } from "../../../../lib/manifest";
import { renderWikilinks } from "../../../../lib/wikilink";
import { parseVerses } from "../../../../lib/verse-parser";
import { correspondencesFor } from "../../../../lib/correspondences";
import CorrespondenceBadges from "../../../../components/CorrespondenceBadges.astro";
import AdminGate from "../../../../components/AdminGate.astro";
import ScriptureChapterNav from "../../../../components/ScriptureChapterNav.astro";
import ScriptureStickyBar from "../../../../components/ScriptureStickyBar.astro";

export async function getStaticPaths() {
  const all = await getCollection("scripture");
  return all
    .filter((e) => e.id.startsWith("cheonjigaebyeokgyeong-hangeul/") && e.data.권 && e.data.장)
    .map((e) => ({
      params: { vol: String(e.data.권), chap: String(e.data.장) },
      props: { entry: e },
    }));
}

const { entry } = Astro.props;
const { 권, 권_이름, 권_이름_한자, 장, 연도, 연도_간지 } = entry.data;
const manifest = await buildCardManifest();

// Parse body into verses by ## N절 ^X-Y-Z headings
type Verse = { num: number; id: string; html: string };
const verses: Verse[] = parseVerses(entry.body ?? "").map((v) => {
  const paragraphs = v.text.split(/\n\s*\n/).filter(Boolean);
  const html = paragraphs
    .map((p) => renderWikilinks(p, manifest))
    .join("\n\n");
  return { num: v.num, id: v.id, html };
});

// Same-volume index (for the progress indicator at the top)
const all = await getCollection("scripture");
const sameVol = all
  .filter((e) => e.id.startsWith("cheonjigaebyeokgyeong-hangeul/") && e.data.권 === 권 && e.data.장)
  .sort((a, b) => (a.data.장 ?? 0) - (b.data.장 ?? 0));
const idx = sameVol.findIndex((e) => e.id === entry.id);
const totalChaps = sameVol.length;
const chapPct = Math.round(((idx + 1) / totalChaps) * 100);

// entry.id is like "cheonjigaebyeokgyeong-hangeul/02_임인편/02-01_장" — reconstruct the content/ path.
const historyPath = `content/scripture/${entry.id}.md`;
---

<Base title={`권 ${권} ${권_이름} · ${장}장 — 천지개벽경 (한글본 백업)`} scriptureSlug="cheonjigaebyeokgyeong-hangeul">
  <AdminGate>
    <ScriptureStickyBar
      scriptureName="천지개벽경 한글본 (백업)"
      scriptureSlug="cheonjigaebyeokgyeong-hangeul"
      scriptureHref="/library/cheonjigaebyeokgyeong-hangeul/"
      context={`권 ${권} ${권_이름} · ${장}장`}
    />
    <div class="chap-head">
      <h1>{장}장 <span class="badge">admin</span></h1>
      <p class="meta">{연도_간지} {연도}</p>
    </div>
    <div class="chap-progress" aria-label={`이 권의 ${idx + 1}번째 장 / 전체 ${totalChaps}장`}>
      <div class="bar"><div class="fill" style={`width: ${chapPct}%`}></div></div>
      <span class="meta">{idx + 1} / {totalChaps}장</span>
    </div>

    <div
      data-pagefind-body
      data-pagefind-filter="scripture:cheonjigaebyeokgyeong-hangeul"
      data-pagefind-meta={`title:권 ${권} ${권_이름} ${장}장 (백업)`}
    >
      <span hidden data-pagefind-filter="kind:경전"></span>
      <span hidden data-pagefind-meta="scriptureName:천지개벽경 한글본 (백업)"></span>
      {verses.map((v) => (
        <section class="verse">
          <h3 class="verse-anchor-heading" id={v.id}>{v.num}절</h3>
          <div class="verse-label" data-pagefind-ignore>
            <a href={`#${v.id}`}>{v.num}절</a>
            <span style="margin-left: 0.5rem; opacity: 0.5">^{v.id}</span>
            <CorrespondenceBadges matches={correspondencesFor("cheonjigaebyeokgyeong-hangeul", v.id)} />
          </div>
          <div class="verse-body" set:html={v.html} />
        </section>
      ))}
    </div>

    <ScriptureChapterNav scriptureSlug="cheonjigaebyeokgyeong-hangeul" currentId={entry.id} />

    <Comments client:idle target={`chapter-hangeul:${권}:${장}`} />
    <History path={historyPath} />
  </AdminGate>
</Base>

<style>
  .badge {
    font-size: 0.5em;
    font-weight: normal;
    color: var(--color-secondary, #d97706);
    border: 1px solid var(--color-secondary, #d97706);
    border-radius: 4px;
    padding: 0.15rem 0.4rem;
    margin-left: 0.4rem;
    vertical-align: middle;
    text-transform: uppercase;
  }
  .chap-head {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    flex-wrap: wrap;
  }
  .chap-head h1 {
    margin: 0;
  }
  .chap-head .meta {
    margin: 0;
  }
  .chap-progress {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin: 0.4rem 0 1.5rem;
  }
  .chap-progress .bar {
    flex: 1;
    height: 4px;
    background: var(--color-rule);
    border-radius: 999px;
    overflow: hidden;
  }
  .chap-progress .fill {
    height: 100%;
    background: var(--color-primary);
    border-radius: 999px;
    transition: width 0.3s ease;
  }
  .chap-progress .meta {
    font-size: 0.78rem;
    color: var(--color-muted);
    flex-shrink: 0;
  }
  .verse-body :global(p) {
    margin: 0.5rem 0;
  }
  .verse-anchor-heading {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
