---
import Base from "../../layouts/Base.astro";
import FeedList from "../../components/feed/FeedList.svelte";
---

<Base title="피드 — jsbooks">
  <section class="feed-page">
    <h1>피드</h1>
    <p class="lede">경전 본문에 달린 최근 댓글을 시간순으로 모아 봅니다.</p>
    <FeedList client:load source="recent" />
  </section>
</Base>

<style>
  .feed-page {
    max-width: 820px;
    margin: 0 auto;
    padding: 0 0.25rem;
  }
  .feed-page h1 {
    margin: 0 0 0.4rem;
    font-size: 1.5rem;
    color: var(--color-primary, #a8352a);
  }
  .lede {
    color: var(--color-muted, #8a807a);
    margin: 0 0 1.2rem;
    font-size: 0.92rem;
  }
</style>
