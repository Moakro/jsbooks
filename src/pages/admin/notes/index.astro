---
import Base from "../../../layouts/Base.astro";
import AdminGate from "../../../components/AdminGate.astro";
import AdminNotePromotion from "../../../components/admin/AdminNotePromotion.svelte";
---

<Base title="댓글 → 주석 승격 — 관리자">
  <AdminGate>
    <h1>댓글 → 주석 승격</h1>
    <p class="meta">
      가치 있는 사용자 댓글을 자료(자료/경전) 마크다운에 정식 주석(footnote)으로
      박아넣습니다. 로컬 dev 모드에서만 vault 파일을 수정하므로, 변경 후 커밋·푸시가
      필요합니다.
    </p>
    <AdminNotePromotion client:load />
  </AdminGate>
</Base>

<style>
  h1 { margin: 0 0 0.4rem; }
  .meta { color: var(--color-muted); margin: 0 0 1.2rem; font-size: 0.9rem; }
</style>
