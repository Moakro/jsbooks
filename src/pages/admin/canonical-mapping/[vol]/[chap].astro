---
import Base from "../../../../layouts/Base.astro";
import { getCollection } from "astro:content";
import { parseVerseGroups } from "../../../../lib/verse-parser";
import { getRawMapping } from "../../../../lib/canonical-mapping";
import AdminGate from "../../../../components/AdminGate.astro";
import SentenceMappingEditor from "../../../../components/admin/SentenceMappingEditor.svelte";
import AdminPreviewSidebar from "../../../../components/admin/AdminPreviewSidebar.svelte";
import Snackbar from "../../../../components/admin/Snackbar.svelte";

export async function getStaticPaths() {
  const all = await getCollection("scripture");
  return all
    .filter((e) => e.id.startsWith("cheonjigaebyeokgyeong/") && e.data.권 && e.data.장)
    .map((e) => ({
      params: { vol: String(e.data.권), chap: String(e.data.장) },
      props: { entry: e },
    }));
}

const { entry } = Astro.props;
const vol = entry.data.권!;
const chap = entry.data.장!;

const all = await getCollection("scripture");

// 한자 본문 그룹별 sentence anchor + 텍스트 + 매핑(있으면) 합성.
type EditorSentence = {
  anchor: string;
  hanja: string;
  hangeul: string;
  reviewed: boolean;
  isVerse: boolean;
};
type EditorGroup = {
  num: number;
  sentences: EditorSentence[];
};

const groups: EditorGroup[] = parseVerseGroups(entry.body ?? "").map((g) => ({
  num: g.num,
  sentences: g.sentences.map((s) => {
    const m = getRawMapping(s.anchor);
    const raw = s.text ?? "";
    const isVerse = raw.startsWith("> ");
    const hanja = isVerse ? raw.slice(2).trim() : raw;
    return {
      anchor: s.anchor,
      hanja,
      hangeul: m?.hangeul ?? "",
      reviewed: !!m?.reviewed,
      isVerse,
    };
  }),
}));

const sameVol = all
  .filter((e) => e.id.startsWith("cheonjigaebyeokgyeong/") && e.data.권 === vol && e.data.장)
  .sort((a, b) => (a.data.장 ?? 0) - (b.data.장 ?? 0));
const idx = sameVol.findIndex((e) => e.id === entry.id);
const prev = idx > 0 ? sameVol[idx - 1] : null;
const next = idx < sameVol.length - 1 ? sameVol[idx + 1] : null;

const totalSentences = groups.reduce((n, g) => n + g.sentences.length, 0);
const mappedSentences = groups.reduce(
  (n, g) => n + g.sentences.filter((s) => s.hangeul.length > 0).length,
  0,
);
---

<Base title={`매핑 권${vol} ${chap}장 — admin`}>
  <AdminGate>
    <header class="hd">
      <p class="crumb">
        <a href="/admin/canonical-mapping/">← 매핑 인덱스</a>
      </p>
      <h1>권 {vol} · {chap}장 매핑·편집</h1>
      <p class="meta">{entry.data.권_이름} ({entry.data.연도_간지} {entry.data.연도})</p>
      <nav class="page-nav">
        {prev && <a href={`/admin/canonical-mapping/${vol}/${prev.data.장}/`}>← {prev.data.장}장</a>}
        {!prev && <span class="muted">←</span>}
        <span>·</span>
        <a
          href={`/library/cheonjigaebyeokgyeong/${vol}/${chap}/`}
          class="preview-link"
          data-preview-title={`공개 페이지 — 권 ${vol} ${chap}장`}
        >👁 공개 페이지</a>
        <span>·</span>
        <a
          href={`/library/cheonjigaebyeokgyeong-hangeul/${vol}/${chap}/`}
          class="preview-link"
          data-preview-title={`한글본 백업 — 권 ${vol} ${chap}장`}
        >👁 한글본 백업</a>
        <span>·</span>
        {next && <a href={`/admin/canonical-mapping/${vol}/${next.data.장}/`}>{next.data.장}장 →</a>}
        {!next && <span class="muted">→</span>}
      </nav>
    </header>

    <p class="meta">
      한자 sentence {totalSentences}개 · 한글 매핑 {mappedSentences}/{totalSentences}
      ({totalSentences > 0 ? Math.round((mappedSentences * 100) / totalSentences) : 0}%)
    </p>

    <SentenceMappingEditor client:load groups={groups} vol={vol} chap={chap} />
    <AdminPreviewSidebar client:load />
    <Snackbar client:load />
  </AdminGate>
</Base>

<script is:inline>
  // .preview-link 클릭 → 새 탭 대신 어드민 사이드바 iframe으로 열기.
  (function () {
    document.addEventListener("click", (e) => {
      const a = e.target instanceof Element ? e.target.closest("a.preview-link") : null;
      if (!a) return;
      if (e.metaKey || e.ctrlKey || e.shiftKey) return; // 새 탭 단축키는 그대로
      const href = a.getAttribute("href");
      const title = a.getAttribute("data-preview-title") || a.textContent || "";
      if (!href) return;
      const api = window.__adminPreview;
      if (!api) return; // 사이드바 hydrate 전 — 폴백으로 그냥 이동
      e.preventDefault();
      api.open(href, title);
    });
  })();
</script>

<style>
  .hd { margin-bottom: 1rem; }
  .crumb { font-size: 0.85rem; color: var(--color-muted); margin: 0; }
  .crumb a { color: inherit; }
  h1 { margin: 0.4rem 0 0.2rem; font-size: 1.3rem; }
  .meta { color: var(--color-muted); margin: 0; font-size: 0.9rem; }
  .page-nav {
    display: flex;
    gap: 0.6rem;
    align-items: center;
    font-size: 0.85rem;
    margin-top: 0.4rem;
    flex-wrap: wrap;
  }
  .page-nav .muted { color: var(--color-muted); }
  .warn {
    padding: 0.6rem 0.9rem;
    background: #fef3c7;
    border: 1px solid #f59e0b;
    border-radius: 6px;
    color: #92400e;
  }
</style>
