---
import Base from "../../../../layouts/Base.astro";
import { getCollection } from "astro:content";
import { parseVerses } from "../../../../lib/verse-parser";
import { getAllMappings } from "../../../../lib/canonical-mapping";
import AdminGate from "../../../../components/AdminGate.astro";
import ChapterEditor from "../../../../components/admin/ChapterEditor.svelte";

export async function getStaticPaths() {
  const all = await getCollection("scripture");
  return all
    .filter((e) => e.id.startsWith("cheonjigaebyeokgyeong/") && e.data.권 && e.data.장)
    .map((e) => ({
      params: { vol: String(e.data.권), chap: String(e.data.장) },
      props: { entry: e },
    }));
}

const { entry } = Astro.props;
const vol = entry.data.권!;
const chap = entry.data.장!;

const all = await getCollection("scripture");

const tempEntry = all.find(
  (e) => e.id.startsWith("cheonjigaebyeokgyeong-hangeul/") && e.data.권 === vol && e.data.장 === chap,
);

const mapping = getAllMappings();
const initialMapping: Record<string, { hangeul: string[]; reviewed: boolean; confidence?: number }> = {};
for (const [k, v] of Object.entries(mapping.verses)) {
  initialMapping[k] = {
    hangeul: [...(v.hangeul ?? [])],
    reviewed: !!v.reviewed,
    ...(v.confidence != null ? { confidence: v.confidence } : {}),
  };
}

const initialHanja = parseVerses(entry.body ?? "").map((v) => ({ id: v.id, text: v.text }));
const initialHangeul = tempEntry
  ? parseVerses(tempEntry.body ?? "").map((v) => ({ id: v.id, text: v.text }))
  : [];

const sameVol = all
  .filter((e) => e.id.startsWith("cheonjigaebyeokgyeong/") && e.data.권 === vol && e.data.장)
  .sort((a, b) => (a.data.장 ?? 0) - (b.data.장 ?? 0));
const idx = sameVol.findIndex((e) => e.id === entry.id);
const prev = idx > 0 ? sameVol[idx - 1] : null;
const next = idx < sameVol.length - 1 ? sameVol[idx + 1] : null;

const hanjaEntryId = entry.id;
const hangeulEntryId = tempEntry?.id ?? "";
---

<Base title={`매핑 권${vol} ${chap}장 — admin`}>
  <AdminGate>
    <header class="hd">
      <p class="crumb">
        <a href="/admin/canonical-mapping/">← 매핑 인덱스</a>
      </p>
      <h1>권 {vol} · {chap}장 매핑·편집</h1>
      <p class="meta">{entry.data.권_이름} ({entry.data.연도_간지} {entry.data.연도})</p>
      <nav class="page-nav">
        {prev && <a href={`/admin/canonical-mapping/${vol}/${prev.data.장}/`}>← {prev.data.장}장</a>}
        {!prev && <span class="muted">←</span>}
        <span>·</span>
        <a href={`/library/cheonjigaebyeokgyeong/${vol}/${chap}/`} target="_blank">공개 페이지 ↗</a>
        <span>·</span>
        <a href={`/library/cheonjigaebyeokgyeong-hangeul/${vol}/${chap}/`} target="_blank">한글본 백업 ↗</a>
        <span>·</span>
        {next && <a href={`/admin/canonical-mapping/${vol}/${next.data.장}/`}>{next.data.장}장 →</a>}
        {!next && <span class="muted">→</span>}
      </nav>
    </header>

    {!hangeulEntryId && (
      <p class="warn">⚠ 임시 한글본 章 파일을 찾지 못했습니다.</p>
    )}

    {hangeulEntryId && (
      <ChapterEditor
        client:load
        hanjaEntryId={hanjaEntryId}
        hangeulEntryId={hangeulEntryId}
        initialHanja={initialHanja}
        initialHangeul={initialHangeul}
        initialMapping={initialMapping}
      />
    )}
  </AdminGate>
</Base>

<style>
  .hd { margin-bottom: 1rem; }
  .crumb { font-size: 0.85rem; color: var(--color-muted); margin: 0; }
  .crumb a { color: inherit; }
  h1 { margin: 0.4rem 0 0.2rem; font-size: 1.3rem; }
  .meta { color: var(--color-muted); margin: 0; font-size: 0.9rem; }
  .page-nav {
    display: flex;
    gap: 0.6rem;
    align-items: center;
    font-size: 0.85rem;
    margin-top: 0.4rem;
    flex-wrap: wrap;
  }
  .page-nav .muted { color: var(--color-muted); }
  .warn {
    padding: 0.6rem 0.9rem;
    background: #fef3c7;
    border: 1px solid #f59e0b;
    border-radius: 6px;
    color: #92400e;
  }
</style>
