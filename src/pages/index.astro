---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";

const scriptureEntries = await getCollection("scripture");
const chapterCount = scriptureEntries.filter((e) => "장" in e.data && e.data.장).length;

const people = (await getCollection("people")).length;
const places = (await getCollection("places")).length;
const dosu = (await getCollection("dosu")).length;
const terms = (await getCollection("terms")).length;
const dates = (await getCollection("dates")).length;
---

<Base title="jsbooks — 증산계열 경전 디지털 라이브러리">
  <section class="lead">
    <h1>jsbooks</h1>
    <p>
      증산계열 경전을 옵시디언 마크다운 구조로 디지털화한 학술 친화 라이브러리.
      사용자는 자기에게 맞는 경전만 골라 활성화할 수 있습니다.
    </p>
  </section>

  <div class="grid">
    <a class="tile primary" href="/scripture/">
      <h2>경전</h2>
      <p>
        본문·인물·지명·도수·용어·시기. 천지개벽경 9편 96장 ({chapterCount}개 장)
        + 참조 카드 {people + places + dosu + terms + dates}건.
      </p>
    </a>

    <a class="tile" href="/news/">
      <h2>소식</h2>
      <p>jsbooks의 공지·업데이트·릴리스·로드맵.</p>
    </a>

    <a class="tile" href="/feed/">
      <h2>피드</h2>
      <p>사용자 댓글·짧은 글·답사기·사진의 시간순 흐름.</p>
    </a>
  </div>
</Base>

<style>
  .lead {
    margin: 1.5rem 0 2.5rem;
  }
  .lead h1 {
    color: var(--color-primary);
    font-size: 2rem;
    margin: 0 0 0.5rem;
  }
  .lead p {
    color: var(--color-fg);
    font-size: 1.05rem;
    line-height: 1.7;
  }
  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-bottom: 3rem;
  }
  @media (min-width: 720px) {
    .grid {
      grid-template-columns: 1.4fr 1fr 1fr;
    }
  }
  .tile {
    display: block;
    border: 1px solid var(--color-rule);
    border-radius: 8px;
    padding: 1.1rem 1.2rem;
    text-decoration: none;
    color: var(--color-fg);
    background: var(--color-bg);
    transition: border-color 0.18s ease, background 0.18s ease;
  }
  .tile:hover {
    border-color: var(--color-primary);
    background: var(--color-primary-bg);
  }
  .tile h2 {
    margin: 0 0 0.4rem;
    color: var(--color-primary);
    font-size: 1.2rem;
  }
  .tile.primary {
    border-color: var(--color-primary);
    background: var(--color-primary-bg);
  }
  .tile.primary:hover {
    background: var(--color-bg);
  }
  .tile p {
    margin: 0;
    color: var(--color-fg);
    font-size: 0.95rem;
    line-height: 1.6;
  }
</style>
