---
import SideCard from "../components/SideCard.svelte";
import SearchBox from "../components/SearchBox.svelte";

interface Props {
  title: string;
  description?: string;
}
const { title, description = "증산계열 경전 디지털 라이브러리" } = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <a href="/" class="brand">jsbooks</a>
      <nav>
        <a href="/scripture/">경전</a>
        <a href="/people/">인물</a>
        <a href="/places/">지명</a>
        <a href="/dosu/">도수</a>
        <a href="/terms/">용어</a>
        <a href="/dates/">시기</a>
      </nav>
      <span style="flex: 1"></span>
      <SearchBox client:load />
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <small>증산계열 경전 디지털 라이브러리 · 학술 친화 자료</small>
    </footer>
    <SideCard client:load />
    <style is:global>
      /* ───────── Design tokens ─────────
       * 태극 페어링: 단심(陽) 메인 + 단청 청록(陰) 보조 + 한지 무채.
       * 사이드바·카드 링크 = 단심 / 페이지 이동 = 청록 / 미존재 = 무채.
       */
      :root {
        /* 양 — 단심 */
        --color-primary: #a8352a;
        --color-primary-soft: #c4564a;
        --color-primary-bg: #fbf3f1;

        /* 음 — 단청 청록 */
        --color-secondary: #1e6e6e;
        --color-secondary-soft: #2c8585;
        --color-secondary-bg: #f0f7f6;

        /* 무채 */
        --color-fg: #1f1c1a;
        --color-muted: #8a807a;
        --color-disabled: #b8b0aa;
        --color-rule: #e8dfd9;
        --color-bg: #fbf8f4;
        --color-hanja: #5b504a;

        /* 의미 별칭 (기존 선언 호환) */
        --bg: var(--color-bg);
        --fg: var(--color-fg);
        --muted: var(--color-muted);
        --hanja: var(--color-hanja);
        --rule: var(--color-rule);
        --accent: var(--color-primary);
        --link: var(--color-primary);
        --link-page: var(--color-secondary);
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --color-primary: #d97765;
          --color-primary-soft: #c0584a;
          --color-primary-bg: #2a1814;

          --color-secondary: #5fb6b3;
          --color-secondary-soft: #4a9c99;
          --color-secondary-bg: #102624;

          --color-fg: #ece6dd;
          --color-muted: #908779;
          --color-disabled: #5a5048;
          --color-rule: #2e2622;
          --color-bg: #15110d;
          --color-hanja: #a89e94;
        }
      }
      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }
      html,
      body {
        margin: 0;
        padding: 0;
        background: var(--bg);
        color: var(--fg);
        font-family:
          -apple-system, BlinkMacSystemFont, "Apple SD Gothic Neo",
          "Pretendard Variable", Pretendard, "Noto Sans KR", "맑은 고딕",
          sans-serif;
        font-size: 17px;
        line-height: 1.7;
      }
      header {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        padding: 1rem 2rem;
        border-bottom: 1px solid var(--rule);
        background: var(--bg);
        position: sticky;
        top: 0;
        z-index: 10;
      }
      header .brand {
        font-weight: 700;
        font-size: 1.1rem;
        text-decoration: none;
        color: var(--accent);
      }
      header nav {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
      }
      header nav a {
        text-decoration: none;
        color: var(--fg);
        font-size: 0.95rem;
      }
      header nav a:hover {
        color: var(--link);
      }
      main {
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem 1.25rem 4rem;
        transition: margin 0.22s ease, max-width 0.22s ease;
      }
      /* Desktop: when sidecard is open, push main to the left of it */
      @media (min-width: 1024px) {
        body[data-sidecard="open"] main {
          margin-left: max(2rem, calc((100vw - 800px - 420px) / 2));
          margin-right: 460px;
        }
        body[data-sidecard="open"] header {
          padding-right: 440px;
        }
      }
      /* Mobile: bottom sheet — leave footer space so it isn't hidden */
      @media (max-width: 1023px) {
        body[data-sidecard="open"] main {
          padding-bottom: 70vh;
        }
      }
      footer {
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem 1.25rem 3rem;
        color: var(--muted);
        border-top: 1px solid var(--rule);
      }
      h1,
      h2,
      h3 {
        line-height: 1.3;
      }
      h1 {
        font-size: 1.7rem;
        margin-top: 0;
      }
      h2 {
        font-size: 1.2rem;
        margin-top: 2rem;
        color: var(--accent);
      }
      a {
        color: var(--color-secondary);
      }
      /* Side-card link (인물·지명·도수·용어·시기): 단심 + 점선 */
      a.wikilink {
        color: var(--color-primary);
        text-decoration: none;
        border-bottom: 1px dotted var(--color-primary);
      }
      a.wikilink:hover {
        background: var(--color-primary-bg);
      }
      /* Page-move link (장 이동, 서문 등): 청록 + 실선 */
      a.wikilink.page,
      a.page-link {
        color: var(--color-secondary);
        text-decoration: none;
        border-bottom: 1px solid var(--color-secondary);
      }
      a.wikilink.page:hover,
      a.page-link:hover {
        background: var(--color-secondary-bg);
      }
      /* Missing target: 무채 + 점선 + 호버 안내 */
      .wikilink-missing {
        color: var(--color-disabled);
        border-bottom: 1px dotted var(--color-disabled);
        cursor: help;
      }
      .verse {
        margin: 1.4rem 0;
        padding-left: 0.75rem;
        border-left: 2px solid var(--rule);
      }
      .verse-label {
        font-size: 0.85rem;
        color: var(--muted);
        margin-bottom: 0.3rem;
      }
      .verse-body {
        white-space: pre-line;
      }
      .index-list {
        list-style: none;
        padding: 0;
      }
      .index-list li {
        padding: 0.4rem 0;
        border-bottom: 1px solid var(--rule);
      }
      .meta {
        color: var(--muted);
        font-size: 0.9rem;
      }
    </style>
  </body>
</html>
