---
import SideCard from "../components/SideCard.svelte";
import SearchBox from "../components/SearchBox.svelte";
import AuthLink from "../components/AuthLink.svelte";
import Sidebar from "../components/Sidebar.astro";
import { HEADER_NAV, resolveSection } from "../data/site-nav";
import { shouldShowSidebar } from "../data/sidebar-nav";

interface Props {
  title: string;
  description?: string;
  /** Slug of the scripture currently being viewed, for sidebar highlight. */
  scriptureSlug?: string | null;
  /** Skip the main card surface — page renders only `pre-main` widgets on the shell. */
  bare?: boolean;
}
const { title, description = "증산계열 경전 도서관 · 북리더 앱", scriptureSlug = null, bare = false } = Astro.props;
const path = Astro.url.pathname;
const activeSection = resolveSection(path);
const sidebarVisible = shouldShowSidebar(path) && activeSection !== null;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header>
      <div class="header-row top">
        <a href="/" class="brand"><span class="brand-js">JS</span><span class="brand-books">Books</span></a>
        <nav class="nav-inline">
          {HEADER_NAV.map((s) => (
            <a href={s.href} class:list={[{ active: activeSection === s.slug }]}>{s.label}</a>
          ))}
        </nav>
        <span style="flex: 1"></span>
        <SearchBox client:load />
        <AuthLink client:load />
      </div>
      <nav class="nav-bottom" aria-label="섹션">
        {sidebarVisible && (
          <button
            id="sidebar-toggle"
            class="hamburger"
            type="button"
            aria-label="사이드바 열기"
            aria-controls="site-sidebar"
          >
            <span></span><span></span><span></span>
          </button>
        )}
        <div class="nav-scroll">
          {HEADER_NAV.map((s) => (
            <a href={s.href} class:list={[{ active: activeSection === s.slug }]}>{s.label}</a>
          ))}
        </div>
      </nav>
    </header>
    <div class="layout">
      {sidebarVisible && (
        <div class="sidebar-wrap" id="site-sidebar">
          <Sidebar currentScriptureSlug={scriptureSlug} />
        </div>
      )}
      <div class={`main-wrap${bare ? " is-bare" : ""}`}>
        <div class="pre-main"><slot name="pre-main" /></div>
        {!bare && (
          <main>
            <slot />
          </main>
        )}
      </div>
    </div>
    <footer>
      <small>증산계열 경전 도서관 · 누구나 무료로 사용, 후원으로 운영합니다</small>
    </footer>
    <SideCard client:load />
    <script>
      // Sidebar toggle: mobile slide-in / desktop optional collapse.
      const btn = document.getElementById("sidebar-toggle");
      const wrap = document.getElementById("site-sidebar");
      function setOpen(open: boolean) {
        if (!wrap) return;
        wrap.classList.toggle("open", open);
        document.body.classList.toggle("sidebar-open", open);
        btn?.setAttribute("aria-expanded", String(open));
      }
      btn?.addEventListener("click", () => {
        const isOpen = wrap?.classList.contains("open") ?? false;
        setOpen(!isOpen);
      });
      // Close when tapping outside on mobile
      document.addEventListener("click", (e) => {
        if (window.innerWidth >= 1024) return;
        if (!wrap?.classList.contains("open")) return;
        const target = e.target as Node;
        if (wrap.contains(target) || btn?.contains(target)) return;
        setOpen(false);
      });

      // Auto-hide header on scroll-down, reveal on scroll-up.
      const headerEl = document.querySelector("header");
      let lastY = window.scrollY;
      let ticking = false;
      function syncHeaderH() {
        if (!headerEl) return;
        const h = headerEl.classList.contains("is-hidden")
          ? 0
          : headerEl.getBoundingClientRect().height;
        document.documentElement.style.setProperty("--header-h", h + "px");
      }
      function onScrollDir() {
        if (!headerEl) return;
        const y = window.scrollY;
        const dy = y - lastY;
        if (Math.abs(dy) < 6) return;
        if (y < 80) {
          headerEl.classList.remove("is-hidden");
        } else if (dy > 0) {
          headerEl.classList.add("is-hidden");
        } else {
          headerEl.classList.remove("is-hidden");
        }
        lastY = y;
        syncHeaderH();
      }
      window.addEventListener(
        "scroll",
        () => {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(() => {
            onScrollDir();
            ticking = false;
          });
        },
        { passive: true },
      );
      window.addEventListener("resize", syncHeaderH);
      window.addEventListener("DOMContentLoaded", syncHeaderH);

      // Manual smooth scroll — requestAnimationFrame so it works even if the
      // browser/OS ignores `behavior: "smooth"` (reduced-motion etc).
      function smoothScrollTo(targetY: number, duration = 550) {
        const startY = window.scrollY;
        const diff = targetY - startY;
        if (Math.abs(diff) < 4) {
          window.scrollTo(0, targetY);
          return;
        }
        const startTime = performance.now();
        function step(now: number) {
          const t = Math.min(1, (now - startTime) / duration);
          // easeInOutCubic
          const eased = t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
          window.scrollTo(0, startY + diff * eased);
          if (t < 1) requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
      }

      function jumpAndFlash(id: string) {
        const el = document.getElementById(id);
        if (!el) return;
        const headerOffset = 110;
        const targetY =
          el.getBoundingClientRect().top + window.scrollY - headerOffset;
        smoothScrollTo(Math.max(0, targetY));
        el.classList.remove("flash");
        void (el as HTMLElement).offsetWidth;
        el.classList.add("flash");
        window.setTimeout(() => el.classList.remove("flash"), 1500);
      }
      function flashHashTarget() {
        const id = decodeURIComponent(location.hash.slice(1));
        if (id) jumpAndFlash(id);
      }
      // Block browser auto-restore so first scroll is ours
      if ("scrollRestoration" in history) history.scrollRestoration = "manual";
      window.addEventListener("DOMContentLoaded", () => {
        window.setTimeout(flashHashTarget, 30);
      });
      window.addEventListener("hashchange", flashHashTarget);
      document.addEventListener("click", (e) => {
        const me = e as MouseEvent;
        if (me.metaKey || me.ctrlKey || me.shiftKey || me.button !== 0) return;
        const a = (e.target as HTMLElement)?.closest?.("a") as HTMLAnchorElement | null;
        if (!a) return;
        const href = a.getAttribute("href");
        if (!href || !href.startsWith("#") || href.length < 2) return;
        const id = decodeURIComponent(href.slice(1));
        const el = document.getElementById(id);
        if (!el) return;
        e.preventDefault();
        history.pushState(null, "", `#${id}`);
        jumpAndFlash(id);
      });
    </script>
    <style is:global>
      /* ───────── Design tokens ─────────
       * 태극 페어링: 단심(陽) 메인 + 단청 청록(陰) 보조 + 한지 무채.
       * 사이드바·카드 링크 = 단심 / 페이지 이동 = 청록 / 미존재 = 무채.
       */
      :root {
        /* 양 — 단심 */
        --color-primary: #a8352a;
        --color-primary-soft: #c4564a;
        --color-primary-bg: #fbf3f1;

        /* 음 — 단청 청록 */
        --color-secondary: #1e6e6e;
        --color-secondary-soft: #2c8585;
        --color-secondary-bg: #f0f7f6;

        /* 무채 — 한지 톤 */
        --color-fg: #1f1c1a;
        --color-muted: #8a807a;
        --color-disabled: #b8b0aa;
        --color-rule: #e8dfd9;
        --color-bg: #f4ede2;        /* app shell — 한지 베이지 */
        --color-surface: #fdfaf4;   /* card surface — 살짝 떠 있는 종이 */
        --color-surface-2: #fbf8f1; /* sidebar — shell보다 한 단계 밝음 */
        --color-hanja: #5b504a;

        /* Elevation */
        --shadow-sm: 0 1px 2px rgba(60, 40, 25, 0.04), 0 1px 3px rgba(60, 40, 25, 0.06);
        --shadow-md: 0 2px 4px rgba(60, 40, 25, 0.05), 0 4px 12px rgba(60, 40, 25, 0.08);
        --shadow-lg: 0 4px 8px rgba(60, 40, 25, 0.06), 0 12px 28px rgba(60, 40, 25, 0.1);
        --radius-sm: 6px;
        --radius-md: 10px;
        --radius-lg: 14px;

        /* 의미 별칭 (기존 선언 호환) */
        --bg: var(--color-bg);
        --fg: var(--color-fg);
        --muted: var(--color-muted);
        --hanja: var(--color-hanja);
        --rule: var(--color-rule);
        --accent: var(--color-primary);
        --link: var(--color-primary);
        --link-page: var(--color-secondary);
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --color-primary: #d97765;
          --color-primary-soft: #c0584a;
          --color-primary-bg: #2a1814;

          --color-secondary: #5fb6b3;
          --color-secondary-soft: #4a9c99;
          --color-secondary-bg: #102624;

          --color-fg: #ece6dd;
          --color-muted: #908779;
          --color-disabled: #5a5048;
          --color-rule: #2e2622;
          --color-bg: #14110d;
          --color-surface: #1c1814;
          --color-surface-2: #1a1612;
          --color-hanja: #a89e94;

          --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.3), 0 1px 3px rgba(0, 0, 0, 0.4);
          --shadow-md: 0 2px 4px rgba(0, 0, 0, 0.35), 0 4px 12px rgba(0, 0, 0, 0.5);
          --shadow-lg: 0 4px 8px rgba(0, 0, 0, 0.4), 0 12px 28px rgba(0, 0, 0, 0.55);
        }
      }
      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }
      html {
        scroll-behavior: smooth;
      }
      html,
      body {
        margin: 0;
        padding: 0;
        background: var(--bg);
        color: var(--fg);
        font-family:
          -apple-system, BlinkMacSystemFont, "Apple SD Gothic Neo",
          "Pretendard Variable", Pretendard, "Noto Sans KR", "맑은 고딕",
          sans-serif;
        font-size: 17px;
        line-height: 1.7;
      }
      /* Anchor jumps land just below the sticky header. */
      .verse {
        scroll-margin-top: 110px;
      }
      /* Outline-only flash: 단심 테두리만 짧게 깜빡 */
      @keyframes jsb-flash {
        0%,
        40% {
          box-shadow: 0 0 0 3px var(--color-primary);
        }
        100% {
          box-shadow: 0 0 0 0 transparent;
        }
      }
      .verse.flash {
        animation: jsb-flash 1.5s ease-out;
        border-radius: 4px;
      }
      :root {
        --header-h: 64px;
      }
      @media (max-width: 1023px) {
        :root {
          --header-h: 110px;
        }
      }
      header {
        background: color-mix(in oklab, var(--color-surface) 88%, transparent);
        backdrop-filter: saturate(140%) blur(12px);
        -webkit-backdrop-filter: saturate(140%) blur(12px);
        border-bottom: 1px solid var(--rule);
        position: sticky;
        top: 0;
        z-index: 10;
        transition: transform 0.22s ease;
      }
      header.is-hidden {
        transform: translateY(-100%);
      }
      .header-row.top {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        padding: 1rem 2rem;
      }
      /* Bottom row exists in DOM for mobile only — hidden on desktop. */
      .nav-bottom {
        display: none;
      }
      header .brand {
        text-decoration: none;
        font-family: "Anton", Impact, "Haettenschweiler",
          "Arial Narrow Bold", "Bebas Neue", system-ui, sans-serif;
        font-weight: 400; /* Anton is single-weight; Impact ignores weight. */
        font-size: 1.6rem;
        line-height: 1;
        letter-spacing: 0.02em;
        display: inline-flex;
      }
      header .brand-js {
        color: var(--color-primary);
      }
      header .brand-books {
        color: var(--color-secondary);
      }
      header nav {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
      }
      header nav a {
        text-decoration: none;
        color: var(--fg);
        font-size: 0.95rem;
        padding: 0.25rem 0.6rem;
        border-radius: 5px;
      }
      header nav a:hover {
        color: var(--color-primary);
        background: var(--color-primary-bg);
      }
      header nav a.active {
        color: var(--color-primary);
        background: var(--color-primary-bg);
        font-weight: 600;
      }
      .hamburger {
        display: none;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 5px;
        width: 36px;
        height: 36px;
        padding: 0;
        background: transparent;
        border: 1px solid transparent;
        border-radius: 5px;
        cursor: pointer;
        box-sizing: border-box;
      }
      .hamburger span {
        display: block;
        width: 22px;
        height: 3px;
        background: var(--color-fg);
        border-radius: 2px;
        flex: none;
      }
      .hamburger:hover {
        border-color: var(--color-primary);
        background: var(--color-primary-bg);
      }
      .layout {
        display: flex;
        align-items: flex-start;
      }
      .sidebar-wrap {
        flex-shrink: 0;
      }
      .main-wrap {
        flex: 1;
        min-width: 0;
        display: flex;
        flex-direction: column;
      }
      .pre-main {
        max-width: 820px;
        margin: 1.25rem auto 0;
        display: flex;
        flex-direction: column;
        gap: 0.9rem;
      }
      .pre-main:empty {
        display: none;
      }
      /* Bare layouts (e.g. home): on tablet+ override the fixed sidebar-aligned
         margin so the pre-main stays horizontally centered. Mobile keeps its
         0.75rem gutter from the default rule below. */
      @media (min-width: 1024px) {
        .main-wrap.is-bare .pre-main {
          margin-left: auto;
          margin-right: auto;
        }
      }
      main {
        max-width: 820px;
        margin: 0.9rem auto 2.5rem;
        padding: 2.25rem 2rem 3rem;
        background: var(--color-surface);
        border: 1px solid var(--color-rule);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-md);
        transition: margin 0.22s ease, max-width 0.22s ease;
      }
      /* Desktop ≥ 1280: sidebar always visible */
      @media (min-width: 1280px) {
        .sidebar-wrap {
          position: sticky;
          top: var(--header-h, 64px);
          height: calc(100vh - var(--header-h, 64px));
          border-right: 1px solid var(--color-rule);
        }
        .pre-main {
          margin: 1.5rem 2rem 0;
        }
        main {
          margin: 0.9rem 2rem 3rem;
          max-width: 820px;
        }
        .layout {
          gap: 0;
        }
      }
      /* Tablet 1024–1279: sidebar always visible (no toggle).
         Header stays single-row, no hamburger. */
      @media (min-width: 1024px) and (max-width: 1279px) {
        .sidebar-wrap {
          position: sticky;
          top: var(--header-h, 64px);
          height: calc(100vh - var(--header-h, 64px));
          border-right: 1px solid var(--color-rule);
        }
        .pre-main {
          margin: 1.25rem 1.5rem 0;
        }
        main {
          margin: 0.9rem 1.5rem 2.5rem;
        }
      }
      /* Mobile < 1024: 2-row header, sidebar slides in from left */
      @media (max-width: 1023px) {
        .pre-main {
          margin: 0.75rem 0.75rem 0;
        }
        main {
          margin: 0.6rem 0.75rem 2rem;
          padding: 1.5rem 1.25rem 2.25rem;
          border-radius: var(--radius-md);
        }
        /* Top row: 브랜드 · spacer · 검색 · 로그인 (햄버거는 하단 좌측) */
        .header-row.top {
          padding: 0.7rem 1rem;
          gap: 0.7rem;
        }
        .nav-inline {
          display: none;
        }
        .nav-bottom {
          display: flex;
          align-items: stretch;
          border-top: 1px solid var(--color-rule);
          background: var(--color-bg);
          position: relative;
        }
        /* Hamburger lives at the left of the bottom nav and stays put even
           when nav-scroll overflows. */
        .nav-bottom .hamburger {
          display: inline-flex;
          flex-shrink: 0;
          margin: 0.3rem 0.5rem 0.3rem 0.7rem;
          align-self: center;
        }
        .nav-bottom .nav-scroll {
          display: flex;
          gap: 0.4rem;
          padding: 0.5rem 1rem 0.5rem 0.5rem;
          overflow-x: auto;
          scrollbar-width: none;
          -ms-overflow-style: none;
          white-space: nowrap;
          flex: 1;
          min-width: 0;
        }
        .nav-bottom .nav-scroll::-webkit-scrollbar {
          display: none;
        }
        .nav-bottom .nav-scroll a {
          flex-shrink: 0;
          text-decoration: none;
          color: var(--color-fg);
          font-size: 0.95rem;
          padding: 0.3rem 0.8rem;
          border-radius: 5px;
          align-self: center;
        }
        .nav-bottom .nav-scroll a.active {
          color: var(--color-primary);
          background: var(--color-primary-bg);
          font-weight: 600;
        }
        .nav-bottom .nav-scroll a:hover {
          color: var(--color-primary);
        }
        .layout {
          display: block;
        }
        .sidebar-wrap {
          position: fixed;
          top: 0;
          left: 0;
          bottom: 0;
          width: min(280px, 80vw);
          background: var(--color-bg);
          z-index: 60;
          transform: translateX(-100%);
          transition: transform 0.22s ease;
          box-shadow: 4px 0 16px rgba(0, 0, 0, 0.1);
          overflow-y: auto;
        }
        .sidebar-wrap.open {
          transform: translateX(0);
        }
        body.sidebar-open::before {
          content: "";
          position: fixed;
          inset: 0;
          background: transparent;
          z-index: 55;
        }
      }
      /* SideCard is an overlay — main content keeps its position.
         (Previously pushed the layout aside; that caused jarring reflows
         when opening cards while reading.) */
      footer {
        max-width: 820px;
        margin: 0 auto;
        padding: 1.5rem 1.25rem 2rem;
        color: var(--muted);
        text-align: center;
        font-size: 0.85rem;
      }
      h1,
      h2,
      h3 {
        line-height: 1.3;
      }
      h1 {
        font-size: 1.7rem;
        margin-top: 0;
      }
      h2 {
        font-size: 1.2rem;
        margin-top: 2rem;
        color: var(--accent);
      }
      a {
        color: var(--color-secondary);
      }
      /* Side-card link (인물·지명·도수·용어·시기): 단심 + 점선 */
      a.wikilink {
        color: var(--color-primary);
        text-decoration: none;
        border-bottom: 1px dotted var(--color-primary);
      }
      a.wikilink:hover {
        background: var(--color-primary-bg);
      }
      /* Page-move link (장 이동, 서문 등): 청록 + 실선 */
      a.wikilink.page,
      a.page-link {
        color: var(--color-secondary);
        text-decoration: none;
        border-bottom: 1px solid var(--color-secondary);
      }
      a.wikilink.page:hover,
      a.page-link:hover {
        background: var(--color-secondary-bg);
      }
      /* Missing target: 무채 + 점선 + 호버 안내 */
      .wikilink-missing {
        color: var(--color-disabled);
        border-bottom: 1px dotted var(--color-disabled);
        cursor: help;
      }
      .verse {
        margin: 1.8rem 0;
        padding-left: 1rem;
        border-left: 2px solid var(--color-rule);
        transition: border-color 0.2s ease;
      }
      .verse:hover {
        border-left-color: var(--color-primary-soft);
      }
      .verse-label {
        font-size: 0.82rem;
        color: var(--muted);
        margin-bottom: 0.45rem;
        display: flex;
        align-items: center;
        gap: 0.4rem;
        flex-wrap: wrap;
      }
      .verse-body {
        white-space: pre-line;
        line-height: 1.95;
        font-size: 1.02rem;
      }
      .index-list {
        list-style: none;
        padding: 0;
      }
      .index-list li {
        padding: 0.4rem 0;
        border-bottom: 1px solid var(--rule);
      }
      .meta {
        color: var(--muted);
        font-size: 0.9rem;
      }
    </style>
  </body>
</html>
