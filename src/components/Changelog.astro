---
/**
 * Site-wide changelog. Surfaces commits that touched any vault content
 * (`content/scripture/**`, `content/{dates,dosu,people,places,terms}/*.md`)
 * and were marked public via the `--public` body token or admin override.
 *
 * Aggregation, dedupe, and category mapping live in lib/history.ts so the
 * admin tooling and any future feed can share the same view.
 */
import { aggregateChangelog } from "../lib/history";
import Icon from "./Icon.svelte";

interface Props {
  /** Maximum number of entries to display. Default 30. */
  limit?: number;
}
const { limit = 30 } = Astro.props;

const recent = aggregateChangelog().slice(0, limit);

function shortDate(iso: string): string {
  return iso.slice(0, 10);
}
---

<section class="changelog">
  <header>
    <span class="ico" aria-hidden="true"><Icon icon="pencil-line" size={18} /></span>
    <h2>Changelog</h2>
    <span class="meta">최근 {recent.length}건</span>
  </header>
  {recent.length === 0 ? (
    <p class="muted">표시할 변경 사항이 아직 없습니다.</p>
  ) : (
    <ol>
      {recent.map((r) => (
        <li>
          <span class="date">{shortDate(r.entry.date)}</span>
          <span class="body">
            <span class="badges">
              {r.categories.map((c) => (
                <a class={`badge badge-${c.group}`} href={c.href}>
                  <span class="badge-group">{c.group === "scripture" ? "경전" : "자료"}</span>
                  <span class="badge-sep">·</span>
                  <span class="badge-label">{c.label}</span>
                </a>
              ))}
            </span>
            <span class="subject">{r.message}</span>
          </span>
        </li>
      ))}
    </ol>
  )}
</section>

<style>
  .changelog {
    background: linear-gradient(180deg, #ffffff 0%, var(--color-bg, #fbf8f4) 100%);
    border: 1px solid var(--color-rule, #e8dfd9);
    border-radius: 10px;
    padding: 1rem 1.2rem 1.1rem;
    margin: 0 0 1rem;
    box-shadow:
      0 1px 2px rgba(60, 40, 25, 0.04),
      0 2px 8px rgba(60, 40, 25, 0.06);
  }
  .changelog header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.7rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--color-rule, #e8dfd9);
  }
  .changelog .ico {
    display: inline-flex;
    color: var(--color-primary, #a8352a);
  }
  .changelog h2 {
    margin: 0;
    flex: 1;
    font-size: 1rem;
    color: var(--color-primary, #a8352a);
  }
  .changelog .meta {
    font-size: 0.78rem;
    color: var(--color-muted, #8a807a);
    font-variant-numeric: tabular-nums;
  }
  .changelog .muted {
    margin: 0;
    color: var(--color-muted, #8a807a);
    font-size: 0.9rem;
  }
  .changelog ol {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }
  .changelog li {
    display: grid;
    grid-template-columns: 6.5em 1fr;
    column-gap: 0.7rem;
    align-items: baseline;
    padding: 0.45rem 0;
    border-bottom: 1px solid var(--color-rule, #e8dfd9);
    font-size: 0.92rem;
  }
  .changelog li:last-child {
    border-bottom: none;
  }
  .date {
    color: var(--color-muted, #8a807a);
    font-variant-numeric: tabular-nums;
    font-size: 0.85rem;
  }
  .body {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.4rem 0.55rem;
  }
  .badges {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }
  .badge {
    display: inline-flex;
    align-items: baseline;
    gap: 0.25em;
    padding: 0.08em 0.55em;
    border-radius: 999px;
    font-size: 0.75rem;
    line-height: 1.5;
    text-decoration: none;
    border: 1px solid transparent;
    white-space: nowrap;
  }
  .badge:hover { filter: brightness(0.97); }
  .badge-scripture {
    background: #fbecea;
    color: #a8352a;
    border-color: #f0d5d0;
  }
  .badge-archive {
    background: #f3ece1;
    color: #7a5a32;
    border-color: #e6dac5;
  }
  .badge-sep {
    opacity: 0.55;
  }
  .badge-label {
    font-weight: 600;
  }
  .subject {
    color: var(--color-fg, #1f1c1a);
    line-height: 1.5;
    word-break: keep-all;
    overflow-wrap: anywhere;
  }
</style>
