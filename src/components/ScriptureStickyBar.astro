---
/**
 * Sticky reading-context bar shown under the site header on scripture pages.
 * - Static prefix: scripture name + chapter context (e.g. "권 8 무신편 · 3장")
 * - Dynamic suffix: current verse number, updated by IntersectionObserver
 *   as the user scrolls through `<section class="verse" id="...">` blocks.
 *
 * The verse number element has class `js-sticky-verse` and is updated by
 * the inline script below. If the page has no verses, only the prefix shows.
 */
import ScriptureSearchPanel from "./ScriptureSearchPanel.svelte";

interface Props {
  scriptureName: string;
  /** Optional context line (e.g. "권 8 무신편 · 3장"). */
  context?: string;
  /** Suffix appended after the verse number. Default: "절". */
  verseSuffix?: string;
  /** Scripture home URL (e.g. "/library/cheonjigaebyeokgyeong/"). */
  scriptureHref?: string;
  /** Pagefind filter slug (e.g. "cheonjigaebyeokgyeong"). When set, a search button is shown. */
  scriptureSlug?: string;
}
const {
  scriptureName,
  context,
  verseSuffix = "절",
  scriptureHref,
  scriptureSlug,
} = Astro.props;
---

<div class="sticky-bar" data-sticky-bar>
  <div class="s-left">
    {scriptureHref ? (
      <a class="s-name" href={scriptureHref}>{scriptureName}</a>
    ) : (
      <span class="s-name">{scriptureName}</span>
    )}
    {context && (
      <>
        <span class="s-sep" aria-hidden="true">·</span>
        <a class="s-context" href="#top" data-sticky-top>{context}</a>
      </>
    )}
    <span class="s-verse js-sticky-verse" aria-live="polite"></span>
  </div>
  {scriptureSlug && (
    <ScriptureSearchPanel
      client:load
      scriptureSlug={scriptureSlug}
      scriptureName={scriptureName}
    />
  )}
  <span class="s-prefix-hidden" data-verse-suffix>{verseSuffix}</span>
</div>

<script>
  (function () {
    const bar = document.querySelector("[data-sticky-bar]") as HTMLElement | null;
    if (!bar) return;
    const verseEl = bar.querySelector(".js-sticky-verse") as HTMLElement | null;
    const suffixEl = bar.querySelector("[data-verse-suffix]") as HTMLElement | null;
    if (!verseEl || !suffixEl) return;
    const suffix = suffixEl.textContent ?? "절";
    const verses = Array.from(document.querySelectorAll<HTMLElement>("section.verse"));
    if (verses.length === 0) return;

    function verseNumberFrom(el: HTMLElement): string {
      // Sentence-anchor pages expose the group num explicitly; this is the
      // 절 number to display, even when the section is a non-first sentence.
      const groupNum = el.dataset.groupNum;
      if (groupNum) return groupNum;
      // Legacy verse-anchor pages: the visible label reads "{num}절".
      const label = el.querySelector(".verse-label a");
      if (label) {
        const m = label.textContent?.match(/(\d+)/);
        if (m) return m[1];
      }
      const heading = el.querySelector("h3[id]") as HTMLElement | null;
      return heading?.id ?? "";
    }

    const visible = new Set<HTMLElement>();
    const obs = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) visible.add(e.target as HTMLElement);
          else visible.delete(e.target as HTMLElement);
        }
        if (visible.size === 0) return;
        // Pick the verse closest to the top of the viewport
        const topMost = [...visible].reduce((best, el) => {
          const r = el.getBoundingClientRect();
          if (!best) return { el, top: r.top };
          return r.top < best.top && r.top > -100
            ? { el, top: r.top }
            : best;
        }, null as { el: HTMLElement; top: number } | null);
        if (!topMost) return;
        const num = verseNumberFrom(topMost.el);
        verseEl.textContent = `${num}${suffix}`;
      },
      {
        rootMargin: "-80px 0px -60% 0px",
        threshold: [0, 0.5, 1],
      },
    );
    verses.forEach((v) => obs.observe(v));

    const topLink = bar.querySelector("[data-sticky-top]") as HTMLAnchorElement | null;
    if (topLink) {
      topLink.addEventListener("click", (e) => {
        e.preventDefault();
        window.scrollTo({ top: 0, behavior: "smooth" });
      });
    }
  })();
</script>

<style>
  .sticky-bar {
    position: sticky;
    top: var(--header-h, 0px);
    z-index: 5;
    background: var(--color-bg, #fbf8f4);
    border-bottom: 1px solid var(--color-rule, #e8dfd9);
    padding: 0.75rem 0.85rem;
    margin: -1rem -1.25rem 1rem;
    min-height: 2.75rem;
    font-size: 0.95rem;
    color: var(--color-muted, #8a807a);
    display: flex;
    align-items: center;
    gap: 0.4rem;
    transition: top 0.2s ease;
  }
  .s-left {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
    flex: 1 1 auto;
    min-width: 0;
  }
  .s-name {
    color: var(--color-fg, #1f1c1a);
    font-weight: 700;
    text-decoration: none;
  }
  a.s-name:hover {
    color: var(--color-primary, #a8352a);
  }
  .s-sep {
    color: var(--color-disabled, #b8b0aa);
  }
  .s-context {
    color: var(--color-muted, #8a807a);
    text-decoration: none;
  }
  a.s-context:hover {
    color: var(--color-primary, #a8352a);
  }
  .s-verse {
    color: var(--color-primary, #a8352a);
    font-weight: 500;
  }
  .s-prefix-hidden {
    display: none;
  }
  @media (min-width: 800px) {
    .sticky-bar {
      margin: -1rem -2rem 1rem;
      padding: 0.75rem 2rem;
    }
  }
</style>
