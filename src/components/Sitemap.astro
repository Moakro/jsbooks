---
/**
 * 메인 페이지 사이트맵 — 헤더 nav 5섹션을 세로로 펼친 카드 grid.
 *
 * 위치: src/pages/index.astro 의 ScriptureChangelog 다음.
 * 톤: 본 사이트 도판 톤 (베이지/진홍/muted) 일관.
 *
 * 데이터:
 *   - 서재: scripture 컬렉션에서 등록된 경전 자동 추출 (이름·홈 URL)
 *   - 자료: 5종 hardcode
 *   - 피드·뉴스·달력: placeholder (실제 데이터 추후 별도 작업)
 */
import { getCollection } from "astro:content";
import Icon from "./Icon.svelte";

// 경전 카탈로그 (WikiHome.astro와 동일 데이터 — _meta.md collection 도입 전까지 hardcode).
type ScriptureCard = {
  slug: string;
  name: string;
  hanja: string;
  editor: string;
  year: number;
};
const SCRIPTURE_ORDER: ScriptureCard[] = [
  { slug: "cheonjigaebyeokgyeong", name: "천지개벽경", hanja: "天地開闢經", editor: "이중성", year: 1946 },
  { slug: "donggokbiseo", name: "동곡비서", hanja: "銅谷秘書", editor: "이춘풍", year: 1990 },
  { slug: "hwaeundang-silgi", name: "화은당실기", hanja: "華恩堂實記", editor: "김병철", year: 1960 },
];

// 등록된 경전만 노출 (콘텐츠 collection에서 prefix가 발견되는 것)
const all = await getCollection("scripture");
const presentSlugs = new Set<string>();
for (const e of all) {
  const slash = e.id.indexOf("/");
  const slug = slash > 0 ? e.id.slice(0, slash) : e.id;
  presentSlugs.add(slug);
}
const scriptures = SCRIPTURE_ORDER
  .filter((s) => presentSlugs.has(s.slug))
  .sort((a, b) => a.name.localeCompare(b.name, "ko"));

type SitemapCard = {
  label: string;
  href: string;
  note?: string;
  placeholder?: boolean;
};
type SitemapSection = {
  slug: string;
  label: string;
  href: string;
  cards?: SitemapCard[];
};

const SECTIONS: SitemapSection[] = [
  {
    slug: "scripture",
    label: "서재",
    href: "/library/",
    // cards 비워두고 별도 markup으로 경전 카드 렌더 (scriptures 변수 사용)
  },
  {
    slug: "archive",
    label: "자료",
    href: "/archive/people/",
    cards: [
      { label: "인물", href: "/archive/people/" },
      { label: "장소", href: "/archive/places/" },
      { label: "도수", href: "/archive/dosu/" },
      { label: "용어", href: "/archive/terms/" },
      { label: "시기", href: "/archive/dates/" },
    ],
  },
  {
    slug: "feed",
    label: "피드",
    href: "/feed/",
    // TODO: D1에서 최근 활동 끌어오기. 우선 placeholder 3개.
    cards: [
      { label: "최근 댓글", href: "/feed/comments/", note: "데이터 준비 중", placeholder: true },
      { label: "짧은 글", href: "/feed/posts/", note: "데이터 준비 중", placeholder: true },
      { label: "답사기·사진", href: "/feed/visits/", note: "데이터 준비 중", placeholder: true },
    ],
  },
  {
    slug: "news",
    label: "뉴스",
    href: "/news/",
    // TODO: content/news/ collection이 생기면 최신 3개 끌어오기.
    cards: [
      { label: "공지", href: "/news/category/notice/", note: "데이터 준비 중", placeholder: true },
      { label: "업데이트", href: "/news/category/update/", note: "데이터 준비 중", placeholder: true },
      { label: "릴리스", href: "/news/category/release/", note: "데이터 준비 중", placeholder: true },
    ],
  },
  {
    slug: "calendar",
    label: "달력",
    href: "/calendar/",
    cards: [
      { label: "오늘 ±7일 일정", href: "/calendar/", note: "데이터 준비 중", placeholder: true },
    ],
  },
];
---

<nav class="sitemap" aria-label="사이트맵">
  {SECTIONS.map((sec) => (
    <section class="sm-section">
      <a class="sm-head" href={sec.href}>
        <span class="sm-label">{sec.label}</span>
        <span class="sm-chev" aria-hidden="true">
          <Icon icon="arrow-right" size={14} strokeWidth={1.7} />
        </span>
      </a>
      <div class="sm-grid" data-section={sec.slug}>
        {sec.slug === "scripture" ? (
          scriptures.map((s) => (
            <a class="sm-card sm-card-scripture" href={`/library/${s.slug}/`}>
              <span class="sc-title">
                <span class="sc-name">{s.name}</span>
                <span class="sc-hanja">{s.hanja}</span>
              </span>
              <span class="sc-meta">
                <span>{s.editor}</span>
                <span class="sc-dot" aria-hidden="true">·</span>
                <span>{s.year}</span>
              </span>
            </a>
          ))
        ) : (
          sec.cards?.map((c) => (
            <a class:list={["sm-card", { placeholder: c.placeholder }]} href={c.href}>
              <span class="sm-card-label">{c.label}</span>
              {c.note && <span class="sm-card-note">{c.note}</span>}
            </a>
          ))
        )}
      </div>
    </section>
  ))}
</nav>

<style>
  .sitemap {
    display: flex;
    flex-direction: column;
    gap: 2.2rem;
    margin: 1rem 0;
  }
  .sm-section {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .sm-head {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    align-self: flex-start;
    padding-bottom: 0.4rem;
    border-bottom: 2px solid var(--color-primary, #a8352a);
    color: var(--color-primary, #a8352a);
    font-weight: 600;
    font-size: 1.15rem;
    text-decoration: none;
    transition: border-color 0.15s ease, color 0.15s ease, gap 0.15s ease;
  }
  .sm-head:hover {
    border-color: var(--color-primary, #a8352a);
    gap: 0.55rem;
  }
  .sm-chev {
    display: inline-flex;
    opacity: 0.7;
    transition: transform 0.15s ease, opacity 0.15s ease;
  }
  .sm-head:hover .sm-chev {
    opacity: 1;
    transform: translateX(2px);
  }

  .sm-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0.7rem;
  }
  /* 카드가 너무 적으면(예: 달력 1개) 좌측 정렬 유지하면서 너비 제한 */
  .sm-grid[data-section="calendar"] {
    grid-template-columns: minmax(180px, 340px);
  }

  .sm-card {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.9rem 1.1rem;
    border: 1px solid var(--color-rule, #e8dfd9);
    border-radius: 10px;
    background: linear-gradient(180deg, #ffffff 0%, var(--color-bg, #fbf8f4) 100%);
    color: var(--color-fg, #1f1c1a);
    text-decoration: none;
    box-shadow:
      0 1px 2px rgba(60, 40, 25, 0.04),
      0 2px 8px rgba(60, 40, 25, 0.06);
    transition:
      transform 0.18s ease,
      box-shadow 0.18s ease,
      border-color 0.18s ease;
  }
  .sm-card:hover {
    transform: translateY(-2px);
    border-color: var(--color-primary, #a8352a);
    box-shadow:
      0 2px 4px rgba(168, 53, 42, 0.08),
      0 8px 20px rgba(60, 40, 25, 0.1);
  }
  .sm-card.placeholder {
    background: var(--color-surface-2, #f6efe9);
    color: var(--color-muted, #8a807a);
    box-shadow: 0 1px 2px rgba(60, 40, 25, 0.03);
  }
  .sm-card.placeholder:hover {
    transform: translateY(-1px);
    color: var(--color-fg, #1f1c1a);
  }
  /* 모바일에서는 그림자 살짝 약하게 (compositing 비용 + 시각 노이즈 절감) */
  @media (max-width: 1023px) {
    .sm-card {
      box-shadow: 0 1px 2px rgba(60, 40, 25, 0.05);
    }
    .sm-card:hover {
      box-shadow: 0 2px 8px rgba(60, 40, 25, 0.08);
    }
  }
  @media (prefers-color-scheme: dark) {
    .sm-card {
      background: linear-gradient(180deg, #2c2418 0%, var(--color-bg, #1f1c1a) 100%);
      box-shadow:
        0 1px 2px rgba(0, 0, 0, 0.25),
        0 2px 8px rgba(0, 0, 0, 0.35);
    }
    .sm-card:hover {
      box-shadow:
        0 2px 4px rgba(168, 53, 42, 0.25),
        0 8px 20px rgba(0, 0, 0, 0.4);
    }
  }
  .sm-card-label {
    font-weight: 600;
    font-size: 0.95rem;
    line-height: 1.3;
  }
  .sm-card-note {
    font-size: 0.74rem;
    color: var(--color-muted, #8a807a);
    line-height: 1.4;
  }
  .sm-card.placeholder .sm-card-label {
    font-weight: 500;
  }

  /* 경전 카드 — 한글명·한자명·편자·연도 노출 */
  .sm-card-scripture {
    padding: 0.8rem 1rem;
    gap: 0.3rem;
  }
  .sc-title {
    display: inline-flex;
    align-items: baseline;
    gap: 0.45rem;
    flex-wrap: wrap;
  }
  .sc-name {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-fg, #1f1c1a);
    line-height: 1.25;
  }
  .sc-hanja {
    font-size: 0.85rem;
    color: var(--color-muted, #8a807a);
    font-weight: 400;
  }
  .sc-meta {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.78rem;
    color: var(--color-muted, #8a807a);
  }
  .sc-dot {
    color: var(--color-disabled, #b8b0aa);
  }
  .sm-card-scripture:hover .sc-name {
    color: var(--color-primary, #a8352a);
  }
</style>
