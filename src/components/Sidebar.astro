---
import { resolveSection } from "../data/site-nav";
import { SIDEBAR_BY_SECTION, shouldShowSidebar } from "../data/sidebar-nav";
import ScripturesList from "./ScripturesList.svelte";
import Icon from "./Icon.svelte";
import { getCollection } from "astro:content";

interface Props {
  /** Slug of the scripture that's currently being viewed (highlight in list). */
  currentScriptureSlug?: string | null;
}

const { currentScriptureSlug = null } = Astro.props;
const path = Astro.url.pathname;
const showSidebar = shouldShowSidebar(path);
const section = resolveSection(path);

if (showSidebar && !section) {
  // Fall back to no sidebar for unknown sections
}

const blocks = section ? SIDEBAR_BY_SECTION[section] : [];
const isDev = import.meta.env.DEV;

// For 경전 sidebar, we feed the ScripturesList island with all scripture meta.
let scriptureMeta:
  | {
      slug: string;
      name: string;
      name_hanja: string | null;
      editor: string | null;
      edition_date: string | null;
      href: string;
    }[]
  = [];

if (section === "scripture" && blocks.some((b) => b.type === "scriptures-list")) {
  // Future: read from a scriptureMeta collection. For now, hardcode a single
  // entry derived from existing content. When `_meta.md` is added per
  // scripture, swap to: getCollection("scriptureMeta").
  scriptureMeta = [
    {
      slug: "cheonjigaebyeokgyeong",
      name: "천지개벽경",
      name_hanja: "天地開闢經",
      editor: "이중성",
      edition_date: "1946-04-27",
      href: "/library/cheonjigaebyeokgyeong/",
    },
    {
      slug: "donggokbiseo",
      name: "동곡비서",
      name_hanja: "銅谷秘書",
      editor: "이춘풍",
      edition_date: "1990-05-05",
      href: "/library/donggokbiseo/",
    },
    {
      slug: "hwaeundang-silgi",
      name: "화은당실기",
      name_hanja: "華恩堂實記",
      editor: "김병철",
      edition_date: "1960-11-05",
      href: "/library/hwaeundang-silgi/",
    },
  ];
}

function isActiveLink(itemPath: string): boolean {
  if (itemPath === path) return true;
  if (itemPath.endsWith("/") && path.startsWith(itemPath)) return true;
  return false;
}
---

{showSidebar && section && (
  <aside class="sidebar" data-section={section}>
    <button class="sidebar-close" type="button" id="sidebar-close" aria-label="사이드바 닫기" title="사이드바 닫기">
      <Icon icon="chevron-left" size={20} />
    </button>

    {blocks.map((b) => {
      if (b.type === "scriptures-list") {
        return <ScripturesList client:load all={scriptureMeta} currentSlug={currentScriptureSlug} />;
      }
      if (b.type === "section") {
        return (
          <div class="block">
            <h3>{b.label}</h3>
            <ul>
              {b.items.map((it) => (
                <li class:list={[{ active: isActiveLink(it.path) }, it.auth ? "auth-only" : ""]}>
                  <a href={it.path}>{it.label}</a>
                </li>
              ))}
            </ul>
          </div>
        );
      }
      // simple link
      return (
        <div class="block">
          <a class:list={["sidebar-link", { active: isActiveLink(b.path) }, b.auth ? "auth-only" : ""]} href={b.path}>
            {b.icon && <Icon icon={b.icon} size={16} />}
            <span>{b.label}</span>
          </a>
        </div>
      );
    })}

    {section === "scripture" && (
      <div class="block admin-canonical-block" data-admin-only hidden={!isDev}>
        <h3>정식판 (작업중)</h3>
        <ul>
          <li class:list={[{ active: isActiveLink("/library/cheonjigaebyeokgyeong-canonical/") }]}>
            <a href="/library/cheonjigaebyeokgyeong-canonical/">천지개벽경 원문</a>
          </li>
        </ul>
      </div>
    )}

    <div class="block admin-block" data-admin-only hidden>
      <a class:list={["sidebar-link", "admin-link", { active: isActiveLink("/admin/") }]} href="/admin/">
        <Icon icon="shield" size={16} />
        <span>관리자</span>
      </a>
    </div>
  </aside>
)}

<script>
  // Reveal admin-only sidebar items if logged-in user has level >= 4.
  (async function () {
    try {
      const res = await fetch("/api/me", { credentials: "same-origin" });
      if (!res.ok) return;
      const ct = res.headers.get("content-type") ?? "";
      if (!ct.includes("application/json")) return;
      const data = await res.json();
      if (data?.user && (data.user.level ?? 0) >= 4) {
        document.querySelectorAll<HTMLElement>("[data-admin-only]").forEach((el) => {
          el.removeAttribute("hidden");
        });
      }
    } catch {
      // silent
    }
  })();

  // Mobile sidebar close button — mirrors hamburger toggle in Base.astro.
  (function () {
    const closeBtn = document.getElementById("sidebar-close");
    const wrap = document.getElementById("site-sidebar");
    closeBtn?.addEventListener("click", () => {
      wrap?.classList.remove("open");
      document.body.classList.remove("sidebar-open");
      const ham = document.getElementById("sidebar-toggle");
      ham?.setAttribute("aria-expanded", "false");
    });
  })();
</script>

<style>
  .sidebar {
    width: 240px;
    flex-shrink: 0;
    background: var(--color-surface-2);
    padding: 0.5rem 0 1rem;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    min-height: 100%;
  }
  .sidebar-close {
    display: none;
  }
  @media (max-width: 1023px) {
    .sidebar {
      background: var(--color-bg);
      width: 100%;
    }
    .sidebar-close {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      align-self: flex-end;
      margin: 0.3rem 0.7rem 0.4rem;
      width: 36px;
      height: 36px;
      padding: 0;
      background: transparent;
      border: 1px solid transparent;
      border-radius: 6px;
      color: var(--color-fg);
      cursor: pointer;
    }
    .sidebar-close:hover {
      background: var(--color-primary-bg);
      border-color: var(--color-rule);
      color: var(--color-primary);
    }
  }
  .block {
    padding: 0.6rem 0.85rem;
    border-bottom: 1px solid var(--color-rule);
  }
  .block:last-child {
    border-bottom: none;
  }
  .admin-canonical-block {
    margin-top: auto;
    border-top: 1px dashed var(--color-rule);
  }
  .admin-canonical-block h3 {
    color: var(--color-secondary);
  }
  .admin-block {
    margin-top: auto;
    border-top: 1px solid var(--color-rule);
    border-bottom: none;
  }
  .admin-canonical-block + .admin-block {
    margin-top: 0;
  }
  .admin-link {
    color: var(--color-muted);
  }
  .admin-link:hover {
    color: var(--color-secondary);
  }
  h3 {
    font-size: 0.78rem;
    color: var(--color-muted);
    margin: 0 0 0.5rem;
    font-weight: 600;
  }
  ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  li a, .sidebar-link {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.35rem 0.5rem;
    border-radius: 4px;
    text-decoration: none;
    color: var(--color-fg);
    font-size: 0.92rem;
    line-height: 1.35;
  }
  li a:hover, .sidebar-link:hover {
    background: var(--color-primary-bg);
  }
  li.active a, .sidebar-link.active {
    background: var(--color-primary-bg);
    color: var(--color-primary);
    font-weight: 600;
    border-left: 3px solid var(--color-primary);
    padding-left: calc(0.5rem - 3px);
  }
  /* `auth-only` items are visually unchanged for now; in Phase B they will be
     hidden for logged-out users via JS. Kept as a marker class. */
  .auth-only::after {
    /* subtle indicator: dotted underline on label */
  }
</style>
