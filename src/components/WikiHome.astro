---
/**
 * Wiki home content — shown both at `/` (site root) and `/library/` (section root).
 * Renders the scripture catalog. AI search and DayBox are placed in the
 * Base layout's `pre-main` slot by the calling page so they sit outside
 * the main card surface.
 */
import LibraryBadges from "./LibraryBadges.svelte";

interface ScriptureCard {
  slug: string;
  name: string;
  hanja: string;
  editor: string;
  editor_hanja: string;
  year: number;
  description: string;
  tradition: string;
  status: "active" | "wip" | "planned";
}

// Until `_meta.md` collection lands, hardcode the catalog.
const scriptures: ScriptureCard[] = [
  {
    slug: "cheonjigaebyeokgyeong",
    name: "천지개벽경",
    hanja: "天地開闢經",
    editor: "이중성",
    editor_hanja: "李重盛",
    year: 1946,
    description:
      "학암 이중성이 상제님의 9년 천지공사를 권 9편 96장으로 정리한 종합 경전. 신축년(1901)부터 기유년(1909)까지의 행적과 가르침을 편년·편장 단위로 수록.",
    tradition: "증산계열",
    status: "active",
  },
  {
    slug: "donggokbiseo",
    name: "동곡비서",
    hanja: "銅谷秘書",
    editor: "이춘풍",
    editor_hanja: "李春風",
    year: 1990,
    description:
      "김형렬 자제 김찬문과 김자현 자제 김태진의 수기를 동곡 성지에서 비전해 오던 별본을 1990년 이춘풍이 엮어 출간한 경전. 247절에 이르는 도통(道通)·도수(度數)·천지공사 관련 말씀을 담음.",
    tradition: "증산계열",
    status: "active",
  },
  {
    slug: "hwaeundang-silgi",
    name: "화은당실기",
    hanja: "華恩堂實記",
    editor: "김병철",
    editor_hanja: "金炳徹",
    year: 1960,
    description:
      "정사 김병철이 1960년에 편술한 증산법종교 연혁사. 강증산의 따님 화은당(華恩堂) 강순임의 일대기와 6기초공사 과정을 8장으로 정리. 1989년 법종사 김대수가 재간행.",
    tradition: "증산계열",
    status: "active",
  },
];
---

<section class="catalog-section">
  <p class="order-note">
    <svg class="info-ico" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
    경전 순서는 가나다 순
  </p>
  <ul class="catalog">
    {scriptures
      .slice()
      .sort((a, b) => a.name.localeCompare(b.name, "ko"))
      .map((s) => (
      <li class={`card ${s.status}`} data-scripture-slug={s.slug}>
        <a href={`/library/${s.slug}/`} class="card-link">
          <div class="spine"></div>
          <div class="card-body">
            <h3>
              <span class="title-ko">{s.name}</span>
              <span class="title-hanja">{s.hanja}</span>
            </h3>
            <p class="meta-row">
              <span>{s.editor}</span>
              <span class="dot">·</span>
              <span>{s.year}</span>
            </p>
            <p class="desc">{s.description}</p>
          </div>
        </a>
      </li>
    ))}
  </ul>
  <p class="hint">
    새 경전이 추가되면 <a href="/news/" class="page-link">뉴스</a>에서 알려드립니다.
  </p>
</section>
<LibraryBadges client:load mode="scriptures" />

<style>
  .catalog {
    list-style: none;
    padding: 0;
    margin: 0 0 1rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 720px) {
    .catalog {
      grid-template-columns: 1fr 1fr;
    }
  }
  .card {
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    overflow: visible; /* badge가 카드 모서리 바깥으로 노출되도록 */
    box-shadow: var(--shadow-sm);
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
    position: relative;
  }
  .card .card-link { border-radius: var(--radius-md); overflow: hidden; }
  .card:hover {
    border-color: var(--color-primary);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }
  .card-link {
    display: flex;
    text-decoration: none;
    color: var(--color-fg);
    min-height: 140px;
  }
  .spine {
    width: 8px;
    flex-shrink: 0;
    background: linear-gradient(
      180deg,
      var(--color-primary) 0%,
      var(--color-primary-soft) 100%
    );
  }
  .card-body {
    padding: 1.1rem 1.25rem 1rem;
    flex: 1;
    min-width: 0;
  }
  .card h3 {
    margin: 0 0 0.35rem;
    font-size: 1.18rem;
    color: var(--color-primary);
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.4rem;
    line-height: 1.3;
  }
  .title-ko {
    font-weight: 600;
  }
  .title-hanja {
    color: var(--color-hanja);
    font-size: 0.82em;
    font-weight: normal;
    letter-spacing: 0.02em;
  }
  .meta-row {
    margin: 0 0 0.6rem;
    font-size: 0.85rem;
    color: var(--color-muted);
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    align-items: baseline;
  }
  .dot {
    opacity: 0.5;
  }
  .desc {
    margin: 0;
    color: var(--color-fg);
    font-size: 0.92rem;
    line-height: 1.65;
  }
  .order-note {
    margin: 0 0 0.7rem;
    font-size: 0.78rem;
    color: var(--color-primary);
    text-align: right;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.3rem;
  }
  .info-ico {
    flex-shrink: 0;
    opacity: 0.85;
  }
  .hint {
    color: var(--color-muted);
    font-size: 0.88rem;
  }
</style>
