---
/**
 * Wiki home content — shown both at `/` (site root) and `/wiki/` (section root).
 * Shows the scripture catalog and a prompt-style entry point.
 */

interface ScriptureCard {
  slug: string;
  name: string;
  hanja: string;
  editor: string;
  editor_hanja: string;
  year: number;
  description: string;
  tradition: string;
  status: "active" | "wip" | "planned";
}

// Until `_meta.md` collection lands, hardcode the catalog.
const scriptures: ScriptureCard[] = [
  {
    slug: "cheonjigaebyeokgyeong",
    name: "천지개벽경",
    hanja: "天地開闢經",
    editor: "이중성",
    editor_hanja: "李重盛",
    year: 1946,
    description:
      "학암 이중성이 강증산의 9년 천지공사를 권 9편 96장으로 정리한 종합 경전. 신축년(1901)부터 기유년(1909)까지의 행적과 가르침을 편년·편장 단위로 수록.",
    tradition: "증산계열",
    status: "active",
  },
];
---

<section class="lead">
  <h1>jsbooks</h1>
  <p>
    증산계열 경전 디지털 라이브러리. 사용자는 자기에게 맞는 경전을 좌측에서
    선택해 노출할 수 있습니다.
  </p>
</section>

<form class="prompt" action="/search/" method="get" role="search">
  <input
    type="search"
    name="q"
    placeholder="찾으시는 절·인물·뜻을 입력하세요. (예: 이마두, 단주의 원한, 무신납월공사)"
    autocomplete="off"
    spellcheck="false"
  />
  <button type="submit" class="go" aria-label="검색">→</button>
</form>

<section class="catalog-section">
  <h2>등록된 경전</h2>
  <ul class="catalog">
    {scriptures.map((s) => (
      <li class={`card ${s.status}`}>
        <a href={`/wiki/${s.slug}/`} class="card-link">
          <h3>
            {s.name}
            <span class="hanja">({s.hanja})</span>
          </h3>
          <p class="row meta-row">
            <span class="tradition">{s.tradition}</span>
            <span class="dot">·</span>
            <span>{s.editor} ({s.editor_hanja})</span>
            <span class="dot">·</span>
            <span>{s.year}</span>
          </p>
          <p class="desc">{s.description}</p>
        </a>
      </li>
    ))}
  </ul>
  <p class="hint">
    추가될 경전은 <a href="/news/" class="page-link">뉴스</a>에서 안내됩니다.
  </p>
</section>

<style>
  .lead {
    margin: 1.5rem 0 1.5rem;
  }
  .lead h1 {
    color: var(--color-primary);
    font-size: 2rem;
    margin: 0 0 0.5rem;
  }
  .lead p {
    color: var(--color-fg);
    line-height: 1.7;
  }

  .prompt {
    display: flex;
    align-items: stretch;
    border: 1px solid var(--color-primary);
    border-radius: 10px;
    background: var(--color-primary-bg);
    overflow: hidden;
    margin: 0 0 2.5rem;
  }
  .prompt input {
    flex: 1;
    border: none;
    outline: none;
    padding: 0.9rem 1rem;
    font: inherit;
    font-size: 1rem;
    background: transparent;
    color: var(--color-fg);
  }
  .prompt .go {
    border: none;
    background: var(--color-primary);
    color: var(--color-bg);
    padding: 0 1.1rem;
    cursor: pointer;
    font-size: 1.05rem;
  }
  .prompt .go:hover {
    background: var(--color-primary-soft);
  }

  .catalog-section h2 {
    font-size: 1rem;
    color: var(--color-muted);
    margin: 0 0 0.8rem;
    font-weight: 600;
  }
  .catalog {
    list-style: none;
    padding: 0;
    margin: 0 0 1rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 720px) {
    .catalog {
      grid-template-columns: 1fr 1fr;
    }
  }
  .card {
    border: 1px solid var(--color-rule);
    border-radius: 8px;
    background: var(--color-bg);
    transition: border-color 0.18s ease, background 0.18s ease;
  }
  .card:hover {
    border-color: var(--color-primary);
    background: var(--color-primary-bg);
  }
  .card-link {
    display: block;
    padding: 1rem 1.1rem;
    text-decoration: none;
    color: var(--color-fg);
  }
  .card h3 {
    margin: 0 0 0.4rem;
    font-size: 1.15rem;
    color: var(--color-primary);
  }
  .card .hanja {
    color: var(--color-hanja);
    font-size: 0.78em;
    font-weight: normal;
    margin-left: 0.3rem;
  }
  .row {
    margin: 0.3rem 0 0.6rem;
    font-size: 0.85rem;
    color: var(--color-muted);
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    align-items: baseline;
  }
  .tradition {
    color: var(--color-secondary);
    border: 1px solid var(--color-secondary);
    border-radius: 999px;
    padding: 1px 8px;
    font-size: 0.78rem;
  }
  .dot {
    opacity: 0.6;
  }
  .desc {
    margin: 0.2rem 0 0;
    color: var(--color-fg);
    font-size: 0.92rem;
    line-height: 1.6;
  }
  .hint {
    color: var(--color-muted);
    font-size: 0.88rem;
  }
</style>
