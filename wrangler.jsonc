{
	"compatibility_date": "2026-05-06",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "jsbooks",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"env": {
		"staging": {
			"name": "jsbooks-stage",
			"routes": [
				{ "pattern": "stage.jsbooks.wiki/*", "zone_name": "jsbooks.wiki" }
			]
		}
	}
}
