  },
  "dependencies": {
    "@astrojs/svelte": "^8.0.5",
    "astro": "^6.1.9",
    "marked": "^18.0.2",
    "svelte": "^5.55.5",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260426.1",
    "pagefind": "^1.5.2",
    "wrangler": "^4.85.0"
  }
}