{
  "name": "jsbooks",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && pnpm exec pagefind --site dist/client --output-subdir pagefind",
    "preview": "astro preview",
